@page "/datasets/upload"
@page "/upload"
@using Microsoft.AspNetCore.Components.Forms
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject NavigationManager NavManager
@using TrainWise.Web.Components.Common

<div class="upload-page">
    <section class="tw-section-header animate-fade-up">
        <h1 class="text-gradient">Upload Dataset</h1>
        <p class="subtitle">Prepare your data for training. We support standard tabular formats up to 50MB.</p>
    </section>

    <div class="upload-grid">
        <div class="upload-main animate-fade-up">
            <div class="tw-card main-upload-card">
                <div class="premium-dropzone @(_file != null ? "has-file" : "")">
                    <div class="dropzone-content">
                        <div class="dropzone-icon">
                            @if (_file != null)
                            {
                                <span>📄</span>
                            }
                            else
                            {
                                <span>☁️</span>
                            }
                        </div>
                        <p class="dropzone-text">
                            @if (_file != null)
                            {
                                <span class="file-ready">@_file.Name</span>
                                <span class="file-size-tag">@FormatSize(_file.Size)</span>
                            }
                            else
                            {
                                <span class="primary-text">Drag and drop your file here</span>
                                <span class="secondary-text">or click to browse local files</span>
                            }
                        </p>
                    </div>
                    <InputFile OnChange="OnFileSelected" class="file-input-overlay" />
                </div>

                <div class="upload-controls">
                    <div class="actions-left">
                        @if (_file != null)
                        {
                            <button class="tw-btn-ghost btn-sm" @onclick="ClearFile">Remove File</button>
                        }
                    </div>
                    <div class="actions-right">
                        <button class="tw-btn-primary" @onclick="UploadAsync" disabled="@(_file is null || _isUploading)">
                            @if (_isUploading)
                            {
                                <span class="spinner-inline"></span>
                                <span>Uploading Dataset...</span>
                            }
                            else
                            {
                                <span>🚀 Start Upload</span>
                            }
                        </button>
                    </div>
                </div>

                @if (_response is not null)
                {
                    <div class="tw-card result-panel animate-fade-up">
                        <div class="result-header">
                            <span class="tw-badge success">Upload Successful</span>
                            <h3>@_response.FileName</h3>
                        </div>
                        
                        <div class="result-stats">
                            <div class="res-stat">
                                <label>Dataset ID</label>
                                <code class="tw-mono">@_response.DatasetId</code>
                            </div>
                            @if (_response.IsDuplicate)
                            {
                                <div class="res-stat">
                                    <span class="tw-badge warning">Duplicate detected — reusing existing record</span>
                                </div>
                            }
                        </div>

                        <div class="result-actions">
                            <button class="tw-btn-primary btn-full" @onclick='() => NavManager.NavigateTo($"/datasets/{_response.DatasetId}")'>
                                Analyze Data →
                            </button>
                            <button class="tw-btn-ghost btn-full" @onclick='() => NavManager.NavigateTo($"/datasets/{_response.DatasetId}?runEda=true")'>
                                Quick EDA
                            </button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="message-container animate-fade-up">
                        <span class="tw-badge @(_messageType == "success" ? "success" : "danger") full-width">
                            @_message
                        </span>
                    </div>
                }
            </div>
        </div>

        <aside class="upload-sidebar animate-fade-up" style="animation-delay: 0.1s;">
            <div class="tw-card sidebar-card">
                <h3>Supported Formats</h3>
                <div class="badge-list">
                    <span class="tw-badge info">CSV</span>
                    <span class="tw-badge info">XLSX (Excel)</span>
                </div>
                <p class="sidebar-note">Maximum file size: <strong>50 MB</strong></p>
            </div>

            <div class="tw-card sidebar-card">
                <h3>Upload Tips</h3>
                <ul class="tips-list">
                    <li>Include descriptive column headers in the first row.</li>
                    <li>Ensure numerical columns contain only numbers.</li>
                    <li>Clean null values or choose a strategy in the next step.</li>
                    <li>Remove identifier columns (IDs, Names) to avoid overfitting.</li>
                </ul>
            </div>
        </aside>
    </div>
</div>

@code {
    private IBrowserFile? _file;
    private TrainWise.Web.Models.DatasetUploadResponse? _response;
    private string? _message;
    private string _messageType = "success";
    private bool _isUploading = false;

    private void OnFileSelected(InputFileChangeEventArgs args)
    {
        _file = args.File;
        _response = null;
        _message = null;
    }

    private void ClearFile()
    {
        _file = null;
        _response = null;
        _message = null;
    }

    private async Task UploadAsync()
    {
        if (_file is null) return;

        _isUploading = true;
        _message = null;
        _response = null;

        try
        {
            _response = await DatasetApi.UploadAsync(_file);
            if (_response is not null)
            {
                _message = "Dataset uploaded and registered successfully.";
                _messageType = "success";
                _file = null;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error: {ex.Message}";
            _messageType = "error";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<style>
    .upload-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .upload-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 32px;
        align-items: start;
    }

    .main-upload-card {
        padding: 32px;
    }

    .premium-dropzone {
        position: relative;
        border: 2px dashed var(--border-subtle);
        background: rgba(255, 255, 255, 0.02);
        border-radius: 20px;
        height: 240px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .premium-dropzone:hover {
        border-color: var(--accent-violet);
        background: rgba(129, 140, 248, 0.05);
    }

    .premium-dropzone.has-file {
        border-color: var(--accent-green);
        background: rgba(52, 211, 153, 0.03);
        border-style: solid;
    }

    .file-input-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .dropzone-icon {
        font-size: 3.5rem;
        margin-bottom: 16px;
        opacity: 0.8;
    }

    .dropzone-text {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .primary-text {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-h1);
    }

    .secondary-text {
        color: var(--text-muted);
    }

    .file-ready {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--accent-green);
    }

    .file-size-tag {
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .upload-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 24px;
    }

    .result-panel {
        margin-top: 32px;
        background: var(--bg-elevated);
        border: 1px solid var(--border-active);
        padding: 24px;
    }

    .result-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
    }

    .result-header h3 { margin: 0; font-size: 1.2rem; }

    .result-stats {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
    }

    .res-stat {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .res-stat label {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 600;
    }

    .result-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .btn-full { width: 100%; justify-content: center; }

    .message-container { margin-top: 24px; }
    .full-width { width: 100%; justify-content: center; }

    .sidebar-card h3 {
        font-size: 1rem;
        margin-bottom: 16px;
    }

    .badge-list {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
    }

    .sidebar-note {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .tips-list {
        padding-left: 18px;
        margin: 0;
    }

    .tips-list li {
        font-size: 0.85rem;
        color: var(--text-body);
        margin-bottom: 10px;
        line-height: 1.5;
    }

    .spinner-inline {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-right: 8px;
    }

    @@media (max-width: 1024px) {
        .upload-grid { grid-template-columns: 1fr; }
    }
</style>
