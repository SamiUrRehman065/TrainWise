@page "/datasets/{id}"
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject ILogger<DatasetDetail> Logger
@inject IJSRuntime JSRuntime
@using TrainWise.Web.Components.Common
@using TrainWise.Web.Models

<div class="dataset-detail-page">
    @if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 60px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Analyzing Dataset...</p>
        </div>
    }
    else if (_summary is null)
    {
        <div class="tw-card empty-state animate-fade-up">
            <div class="empty-icon">📂</div>
            <h3>Dataset not found</h3>
            <p class="subtitle">The dataset you're looking for doesn't exist or has been deleted.</p>
            <button class="tw-btn-primary" style="margin-top: 24px;" @onclick='() => NavManager.NavigateTo("/datasets")'>Back to Datasets</button>
        </div>
    }
    else
    {
        <section class="tw-section-header animate-fade-up">
            <h1 class="text-gradient">@_datasetName</h1>
            <p class="subtitle">Detailed metadata, feature analysis, and exploratory insights for this dataset.</p>
            <div class="header-actions">
                <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo($"/datasets/{Id}/eda")'>
                    📊 Open EDA Dashboard
                </button>
                <button class="tw-btn-danger" @onclick="DeleteAsync">
                    🗑️ Delete
                </button>
            </div>
        </section>

        <!-- STATS GRID -->
        <div class="stats-overview-grid animate-fade-up">
            <div class="tw-stat-card">
                <span class="stat-label">Total Rows</span>
                <span class="stat-number">@_summary.RowCount.ToString("N0")</span>
            </div>
            <div class="tw-stat-card">
                <span class="stat-label">Columns</span>
                <span class="stat-number">@_summary.ColumnCount</span>
            </div>
            <div class="tw-stat-card">
                <span class="stat-label">Imbalance Ratio</span>
                <span class="stat-number">@(_summary.ImbalanceRatio?.ToString("0.00") ?? "1.00")</span>
            </div>
            <div class="tw-stat-card">
                <span class="stat-label">Created At</span>
                <span class="stat-number small">@_uploadedAt.ToString("MMM dd, yyyy")</span>
            </div>
        </div>

        <div class="detail-grid">
            <!-- LEFT COLUMN: COLUMNS & PREVIEW -->
            <div class="detail-main animate-fade-up">
                <div class="tw-card">
                    <h3>📁 Feature Definitions</h3>
                    <div class="columns-grid">
                        @foreach (var col in _summary.Columns)
                        {
                            <div class="column-pill">
                                <span class="col-name">@col</span>
                                <span class="tw-badge info">@(_summary.ColumnTypes?.GetValueOrDefault(col, "unknown"))</span>
                            </div>
                        }
                    </div>
                </div>

                @if (_summary.Preview?.Any() == true)
                {
                    <div class="tw-card table-card">
                        <h3>📄 Data Preview (First 5 Rows)</h3>
                        <div class="table-wrapper">
                            <table class="tw-table">
                                <thead>
                                    <tr>
                                        @foreach (var col in _summary.Columns.Take(6))
                                        {
                                            <th>@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _summary.Preview.Take(5))
                                    {
                                        <tr>
                                            @foreach (var cell in row.Take(6))
                                            {
                                                <td>@cell</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <!-- RIGHT COLUMN: EDA & EXPERIMENTS -->
            <div class="detail-sidebar animate-fade-up" style="animation-delay: 0.1s;">
                <div class="tw-card eda-card">
                    <div class="card-header">
                        <h3>🧪 EDA Insights</h3>
                        <button class="tw-btn-ghost btn-xs" @onclick="RunEdaAsync" disabled="_isEdaLoading">
                            @( _isEdaLoading ? "Running..." : "Refresh")
                        </button>
                    </div>

                    @if (_intelligence is null)
                    {
                        <p class="text-muted">Run automated intelligence to see health scores and predictive relevance.</p>
                    }
                    else
                    {
                        <div class="eda-stats">
                            <div class="eda-stat-item">
                                <label>Health Score</label>
                                <span style="color: #22d3ee; font-weight: 700;">@_intelligence.QualityReport.OverallScore.ToString("0") / 100</span>
                            </div>
                            <div class="eda-stat-item">
                                <label>Problem Type</label>
                                <span class="tw-badge info">@_intelligence.Overview.ProblemType</span>
                            </div>
                        </div>

                        <div class="eda-tip">
                            <span class="icon">💡</span>
                            <small>Recommendation: Use <strong>@_intelligence.Overview.ProblemType</strong> models for this dataset.</small>
                        </div>

                        @if (_intelligence.Features.Any(f => !f.IsTarget && f.RelevanceScore > 0))
                        {
                            <h4 class="sub-heading">Predictive Features</h4>
                            <div class="correlation-list">
                                @foreach (var f in _intelligence.Features.Where(f => !f.IsTarget).OrderByDescending(f => f.RelevanceScore).Take(5))
                                {
                                    var width = (int)(f.RelevanceScore * 100);
                                    <div class="corr-item">
                                        <div class="corr-label">
                                            <span>@f.Name</span>
                                            <span class="tw-mono">@((f.RelevanceScore * 100).ToString("0"))%</span>
                                        </div>
                                        <div class="tw-progress-bar">
                                            <div class="progress-fill" style="width:@($"{width}%")"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                <div class="tw-card">
                    <h3>🏆 Related Experiments</h3>
                    @if (_relatedExperiments?.Any() == true)
                    {
                        <div class="related-experiments">
                            @foreach (var exp in _relatedExperiments.Take(4))
                            {
                                <div class="exp-mini-card">
                                    <div class="exp-info">
                                        <span class="exp-name">@exp.ModelName</span>
                                        <span class="exp-meta">@exp.TaskType &middot; @exp.CreatedAt.ToString("MMM dd")</span>
                                    </div>
                                    <button class="tw-btn-ghost btn-xs" @onclick='() => NavManager.NavigateTo($"/experiments/{exp.ExperimentId}")'>
                                        View
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No models trained on this dataset yet.</p>
                        <button class="tw-btn-primary btn-sm" style="width: 100%;" @onclick='() => NavManager.NavigateTo("/training")'>
                            Train Model
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }
    private DatasetSummary? _summary;
    private List<ExperimentListItem>? _relatedExperiments;
    private DatasetIntelligence? _intelligence;
    private bool _isEdaLoading;
    private bool _isLoading = true;
    private string _datasetName = "Dataset Details";
    private DateTime _uploadedAt = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }

        if (string.IsNullOrEmpty(Id))
        {
            _isLoading = false;
            return;
        }
        await LoadDatasetDetails();
    }

    private async Task LoadDatasetDetails()
    {
        try
        {
            if (!Guid.TryParse(Id, out var datasetId))
            {
                _isLoading = false;
                return;
            }

            _summary = await DatasetApi.GetSummaryAsync(datasetId);

            if (_summary is not null)
            {
                _datasetName = $"Dataset {datasetId.ToString()[..8].ToUpper()}";
                var history = await ExperimentApi.GetHistoryAsync(page: 1, pageSize: 50);
                if (history?.Items is not null)
                {
                    _relatedExperiments = history.Items
                        .Where(e => e.DatasetId == datasetId)
                        .OrderByDescending(e => e.CreatedAt)
                        .ToList();
                }
                await RunEdaAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dataset details");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RunEdaAsync()
    {
        if (!Guid.TryParse(Id, out var datasetId)) return;
        _isEdaLoading = true;
        try
        {
            var target = _summary?.Columns.LastOrDefault();
            _intelligence = await DatasetApi.GetIntelligenceAsync(datasetId, target);
        }
        finally
        {
            _isEdaLoading = false;
        }
    }

    private async Task DeleteAsync()
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Permanently delete this dataset and all related experiments?");
        if (!confirmed) return;

        if (Guid.TryParse(Id, out var datasetId))
        {
            if (await DatasetApi.DeleteAsync(datasetId))
                NavManager.NavigateTo("/datasets");
        }
    }
}

<style>
    .dataset-detail-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .stats-overview-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .stat-number.small { font-size: 1.25rem; }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 32px;
        align-items: start;
    }

    .detail-main {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .detail-main h3, .detail-sidebar h3 {
        font-size: 1.1rem;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .columns-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
    }

    .column-pill {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .col-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-h1);
    }

    .table-card { padding: 0 !important; }
    .table-card h3 { padding: 24px 24px 0; }

    .table-wrapper {
        width: 100%;
        overflow-x: auto;
        padding: 24px;
    }

    .tw-table {
        width: 100%;
        border-collapse: collapse;
    }

    .tw-table th {
        text-align: left;
        padding: 12px 16px;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border-subtle);
    }

    .tw-table td {
        padding: 12px 16px;
        font-size: 0.85rem;
        color: var(--text-body);
        border-bottom: 1px solid var(--border-subtle);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    .card-header h3 { margin-bottom: 0; }

    .eda-stats {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
    }

    .eda-stat-item {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
    }

    .eda-stat-item label { color: var(--text-muted); }
    .eda-tip {
        background: rgba(34, 211, 238, 0.05);
        border: 1px solid rgba(34, 211, 238, 0.1);
        border-radius: 8px;
        padding: 10px 14px;
        margin-top: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .eda-tip .icon {
        font-size: 1.2rem;
    }

    .eda-tip small {
        color: var(--text-body);
        line-height: 1.4;
    }

    .eda-tip strong {
        color: var(--accent-cyan);
    }

    .sub-heading {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 0.5px;
        margin: 24px 0 12px;
    }

    .correlation-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .corr-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .corr-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
    }

    .tw-progress-bar {
        height: 6px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: var(--accent-grad);
        border-radius: 10px;
    }

    .related-experiments {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .exp-mini-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        padding: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .exp-info {
        display: flex;
        flex-direction: column;
    }

    .exp-name { font-weight: 600; font-size: 0.85rem; color: var(--text-h1); }
    .exp-meta { font-size: 0.75rem; color: var(--text-muted); }

    .btn-xs { padding: 4px 12px !important; font-size: 0.75rem !important; }

    @@media (max-width: 1200px) {
        .stats-overview-grid { grid-template-columns: repeat(2, 1fr); }
        .detail-grid { grid-template-columns: 1fr; }
    }
</style>
