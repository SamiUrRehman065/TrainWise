@page "/datasets/{id}"
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject ILogger<DatasetDetail> Logger
@inject IJSRuntime JSRuntime
@using TrainWise.Web.Components.Common
@using TrainWise.Web.Models


@if (!SessionState.IsAuthenticated)
{
    <div class="alert alert-warning">
        <p>Please <a href="/login">sign in</a> to view datasets.</p>
    </div>
}
else if (_isLoading)
{
    <div class="card">
        <div class="loading-spinner"></div>
        <p class="muted" style="text-align:center;">Loading dataset details...</p>
    </div>
}
else if (_summary is null)
{
    <div class="empty-state">
        <h3>Dataset not found</h3>
        <p class="muted">The dataset you're looking for doesn't exist or has been deleted.</p>
        <a href="/datasets" class="button primary" style="margin-top:16px;">Back to Datasets</a>
    </div>
}
else
{
    <section class="page-header">
        <div>
            <h1>@_datasetName</h1>
            <p class="lead">Dataset analysis and metadata</p>
        </div>
        <div class="header-actions">
            <button class="button ghost" @onclick="DeleteAsync">Delete</button>
        </div>
    </section>

    @* Overview *@
    <div class="detail-section">
        <h3>Overview</h3>
        <div class="overview-grid">
            <div class="ov-item">
                <span class="ov-label">Created</span>
                <span class="ov-value">@_uploadedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
            <div class="ov-item">
                <span class="ov-label">Rows</span>
                <span class="ov-value">@_summary.RowCount</span>
            </div>
            <div class="ov-item">
                <span class="ov-label">Columns</span>
                <span class="ov-value">@_summary.ColumnCount</span>
            </div>
            <div class="ov-item">
                <span class="ov-label">Imbalance Ratio</span>
                <span class="ov-value">@(_summary.ImbalanceRatio?.ToString("0.00") ?? "N/A")</span>
            </div>
        </div>
    </div>

    @* Columns *@
    @if (_summary.ColumnTypes?.Any() == true)
    {
        <div class="detail-section">
            <h3>Columns</h3>
            <div class="columns-list">
                @foreach (var col in _summary.Columns)
                {
                    <div class="column-item">
                        <span class="col-name">@col</span>
                        <span class="col-type tag">@(_summary.ColumnTypes.GetValueOrDefault(col, "unknown"))</span>
                    </div>
                }
            </div>
        </div>
    }

    @* Data Preview *@
    @if (_summary.Preview?.Any() == true)
    {
        <div class="detail-section">
            <h3>Data Preview</h3>
            <div class="table-container" style="overflow-x:auto;">
                <table>
                    <thead>
                        <tr>
                            @foreach (var col in _summary.Columns.Take(5))
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _summary.Preview.Take(5))
                        {
                            <tr>
                                @foreach (var cell in row)
                                {
                                    <td>@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Related Experiments *@
    <div class="detail-section">
        <h3>Related Experiments</h3>
        @if (_relatedExperiments?.Any() == true)
        {
            <div class="related-list">
                @foreach (var exp in _relatedExperiments.Take(5))
                {
                    <div class="related-row">
                        <div class="related-info">
                            <div class="related-name">@exp.ModelName</div>
                            <div class="related-meta">@exp.TaskType &middot; @exp.CreatedAt.ToString("MMM dd")</div>
                        </div>
                        <a href="@($"/experiments/{exp.ExperimentId}")" class="button small ghost">View</a>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="muted">No experiments yet. <a href="/training">Train a model</a> with this dataset.</p>
        }
    </div>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private DatasetSummary? _summary;
    private List<ExperimentListItem>? _relatedExperiments;
    private bool _isLoading = true;
    private string _datasetName = "Dataset";
    private DateTime _uploadedAt = DateTime.MinValue;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated || string.IsNullOrEmpty(Id))
        {
            _isLoading = false;
            return;
        }

        await LoadDatasetDetails();
    }

    private async Task LoadDatasetDetails()
    {
        try
        {
            if (!Guid.TryParse(Id, out var datasetId))
            {
                _isLoading = false;
                return;
            }

            _summary = await DatasetApi.GetSummaryAsync(datasetId);

            if (_summary is not null)
            {
                _datasetName = $"Dataset {_summary.DatasetId[..8]}...";

                _breadcrumbs = new()
                {
                    new BreadcrumbItem { Label = "Datasets", Url = "/datasets" },
                    new BreadcrumbItem { Label = _datasetName }
                };

                var history = await ExperimentApi.GetHistoryAsync(page: 1, pageSize: 50);
                if (history?.Items is not null)
                {
                    _relatedExperiments = history.Items
                        .Where(e => e.DatasetId == datasetId)
                        .OrderByDescending(e => e.CreatedAt)
                        .ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dataset details for {Id}", Id);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (!await ConfirmDelete())
            return;

        try
        {
            if (!Guid.TryParse(Id, out var datasetId))
                return;

            var success = await DatasetApi.DeleteAsync(datasetId);

            if (success)
            {
                NavManager.NavigateTo("/datasets");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting dataset {Id}", Id);
        }
    }

    private async Task<bool> ConfirmDelete()
    {
        return await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this dataset?");
    }
}

<style>
    .detail-section {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: var(--space-5);
    }

    .detail-section + .detail-section {
        margin-top: var(--space-4);
    }

    .detail-section h3 {
        font-size: 16px;
        margin-bottom: var(--space-4);
        padding-bottom: var(--space-3);
        border-bottom: 1px solid var(--color-border);
    }

    .overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: var(--space-4);
    }

    .ov-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .ov-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--color-text-secondary);
    }

    .ov-value {
        font-family: var(--font-mono);
        font-size: 18px;
    }

    .columns-list {
        display: grid;
        gap: var(--space-2);
    }

    .column-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-3) var(--space-3);
        border: 1px solid var(--color-border);
    }

    .col-name {
        font-weight: 500;
        font-size: 14px;
    }

    .col-type {
        font-size: 10px;
    }

    .related-list {
        display: grid;
        gap: var(--space-2);
    }

    .related-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-3);
        border: 1px solid var(--color-border);
    }

    .related-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .related-name {
        font-size: 14px;
        font-weight: 500;
    }

    .related-meta {
        font-size: 12px;
        color: var(--color-text-secondary);
    }
</style>
