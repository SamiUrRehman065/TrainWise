@page "/datasets"
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using TrainWise.Web.Components.Common


<section class="page-header">
    <div>
        <h1>Datasets</h1>
        <p class="lead">Manage your training datasets.</p>
    </div>
    <div class="header-actions">
        <a href="/upload" class="button primary">Upload Dataset</a>
    </div>
</section>

@if (!SessionState.IsAuthenticated)
{
    <div class="alert alert-warning">
        <p>Please <a href="/login">sign in</a> to view your datasets.</p>
    </div>
}
else
{
    @if (_isLoading)
    {
        <div class="card">
            <div class="loading-spinner"></div>
            <p class="muted" style="text-align:center;">Loading datasets...</p>
        </div>
    }
    else if (_filteredDatasets.Count == 0)
    {
        <div class="empty-state">
            <h3>No datasets yet</h3>
            <p class="muted">Upload your first dataset to get started with training models.</p>
            <a href="/upload" class="button primary" style="margin-top:16px;">Upload Dataset</a>
        </div>
    }
    else
    {
        <FilterBar FilterDefinitions="@_filterDefinitions" OnFilterApplied="OnFilterApplied" />

        <div class="dataset-grid">
            @foreach (var dataset in _paginatedDatasets)
            {
                <div class="dataset-card">
                    <div class="card-header">
                        <h4>@dataset.FileName</h4>
                        <span class="dataset-date">@dataset.UploadedAt.ToString("MMM dd, yyyy")</span>
                    </div>

                    <div class="dataset-stats">
                        <div class="ds-stat">
                            <span class="ds-label">Rows</span>
                            <span class="ds-value">@dataset.RowCount</span>
                        </div>
                        <div class="ds-stat">
                            <span class="ds-label">Columns</span>
                            <span class="ds-value">@dataset.ColumnCount</span>
                        </div>
                        <div class="ds-stat">
                            <span class="ds-label">Size</span>
                            <span class="ds-value">@FormatBytes(dataset.Size)</span>
                        </div>
                    </div>

                    <div class="card-actions">
                        <a href="@($"/datasets/{dataset.DatasetId}")" class="button small">View</a>
                        <a href="/training" class="button ghost small">Train</a>
                        <button class="button ghost small" style="color:var(--color-negative);" @onclick="() => DeleteDatasetAsync(dataset.DatasetId)">Delete</button>
                    </div>
                </div>
            }
        </div>

        <Pagination
            CurrentPage="@_currentPage"
            PageSize="@_pageSize"
            TotalItems="@_filteredDatasets.Count"
            OnPageChanged="OnPageChanged" />
    }
}

@code {
    private List<DatasetListItem> _datasets = new();
    private List<DatasetListItem> _filteredDatasets = new();
    private List<DatasetListItem> _paginatedDatasets = new();
    private bool _isLoading = true;
    private int _currentPage = 1;
    private int _pageSize = 12;
    private List<FilterDefinition> _filterDefinitions = new();
    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem { Label = "Datasets" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDatasets();
        InitializeFilters();
    }

    private async Task LoadDatasets()
    {
        try
        {
            var result = await DatasetApi.GetAllAsync();
            _datasets = result?.Items ?? new();
            _filteredDatasets = _datasets;
            UpdatePaginatedDatasets();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void InitializeFilters()
    {
        _filterDefinitions = new()
        {
            new FilterDefinition
            {
                Key = "created",
                Label = "Created",
                Options = new() { "Today", "This Week", "This Month", "Older" }
            }
        };
    }

    private void OnFilterApplied(Dictionary<string, string> filters)
    {
        _filteredDatasets = _datasets;

        if (filters.ContainsKey("created"))
        {
            var now = DateTime.Now;
            _filteredDatasets = _filteredDatasets.Where(d =>
            {
                var uploaded = d.UploadedAt;
                return filters["created"] switch
                {
                    "Today" => uploaded.Date == now.Date,
                    "This Week" => (now - uploaded).TotalDays < 7,
                    "This Month" => (now - uploaded).TotalDays < 30,
                    "Older" => (now - uploaded).TotalDays >= 30,
                    _ => true
                };
            }).ToList();
        }

        _currentPage = 1;
        UpdatePaginatedDatasets();
    }

    private void OnPageChanged(int page)
    {
        _currentPage = page;
        UpdatePaginatedDatasets();
    }

    private void UpdatePaginatedDatasets()
    {
        var skip = (_currentPage - 1) * _pageSize;
        _paginatedDatasets = _filteredDatasets.Skip(skip).Take(_pageSize).ToList();
    }

    private async Task DeleteDatasetAsync(Guid datasetId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this dataset?"))
            return;

        var success = await DatasetApi.DeleteAsync(datasetId);
        if (success)
        {
            await LoadDatasets();
        }
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<style>
    .dataset-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: var(--space-4);
        margin-bottom: var(--space-5);
    }

    .dataset-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        display: flex;
        flex-direction: column;
    }

    .dataset-card .card-header {
        margin-bottom: 0;
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-4);
    }

    .dataset-card .card-header h4 {
        font-size: 15px;
        margin-bottom: var(--space-1);
        word-break: break-word;
    }

    .dataset-date {
        font-size: 12px;
        color: var(--color-text-secondary);
    }

    .dataset-stats {
        padding: var(--space-4);
        flex: 1;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-3);
    }

    .ds-stat {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .ds-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--color-text-secondary);
    }

    .ds-value {
        font-family: var(--font-mono);
        font-size: 16px;
    }

    .dataset-card .card-actions {
        margin-top: 0;
        padding: var(--space-3) var(--space-4);
    }

    @@media (max-width: 720px) {
        .dataset-grid {
            grid-template-columns: 1fr;
        }

        .dataset-stats {
            grid-template-columns: 1fr;
        }
    }
</style>
