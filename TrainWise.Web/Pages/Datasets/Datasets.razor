@page "/datasets"
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using TrainWise.Web.Components.Common

<div class="datasets-page">
    <section class="tw-section-header">
        <h1 class="text-gradient">My Datasets</h1>
        <p class="subtitle">Manage your training datasets and prepare them for machine learning models.</p>
        <div class="header-actions">
            <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/upload")'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span>Upload Data</span>
            </button>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 60px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Loading datasets...</p>
        </div>
    }
    else if (_filteredDatasets.Count == 0)
        {
            <div class="tw-card empty-state animate-fade-up">
                <div class="empty-icon">📁</div>
                <h3>No datasets yet</h3>
                <p class="subtitle">Upload your first dataset to get started with training models.</p>
                <button class="tw-btn-primary" style="margin-top: 24px;" @onclick='() => NavManager.NavigateTo("/upload")'>
                    Upload Dataset
                </button>
            </div>
        }
        else
        {
            <div class="filter-section animate-fade-up">
                <FilterBar FilterDefinitions="@_filterDefinitions" OnFilterApplied="OnFilterApplied" />
            </div>

            <div class="tw-card table-card animate-fade-up">
                <table class="tw-table">
                    <thead>
                        <tr>
                            <th>Dataset Name</th>
                            <th>Status</th>
                            <th>Rows</th>
                            <th>Cols</th>
                            <th>Size</th>
                            <th>Uploaded</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dataset in _paginatedDatasets)
                        {
                            <tr>
                                <td class="dataset-name-cell">
                                    <div class="dataset-icon">📊</div>
                                    <span>@dataset.FileName</span>
                                </td>
                                <td>
                                    <span class="tw-badge success">Ready</span>
                                </td>
                                <td><code class="tw-mono">@dataset.RowCount.ToString("N0")</code></td>
                                <td><code class="tw-mono">@dataset.ColumnCount.ToString("N0")</code></td>
                                <td><code class="tw-mono">@FormatBytes(dataset.Size)</code></td>
                                <td class="text-muted">@dataset.UploadedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="action-buttons">
                                        <a href="@($"/datasets/{dataset.DatasetId}")" class="tw-btn-ghost btn-xs" title="View Detail">
                                            View
                                        </a>
                                        <button class="tw-btn-primary btn-xs" @onclick='() => NavManager.NavigateTo("/training")'>
                                            Train
                                        </button>
                                        <button class="tw-btn-danger btn-xs" @onclick="() => DeleteDatasetAsync(dataset.DatasetId)" title="Delete">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pagination-section animate-fade-up">
                <Pagination
                    CurrentPage="@_currentPage"
                    PageSize="@_pageSize"
                    TotalItems="@_filteredDatasets.Count"
                    OnPageChanged="OnPageChanged" />
            </div>
        }
</div>

@code {
    private List<DatasetListItem> _datasets = new();
    private List<DatasetListItem> _filteredDatasets = new();
    private List<DatasetListItem> _paginatedDatasets = new();
    private bool _isLoading = true;
    private int _currentPage = 1;
    private int _pageSize = 12;
    private List<FilterDefinition> _filterDefinitions = new();

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        await LoadDatasets();
        InitializeFilters();
    }

    private async Task LoadDatasets()
    {
        try
        {
            var result = await DatasetApi.GetAllAsync();
            _datasets = result?.Items ?? new();
            _filteredDatasets = _datasets;
            UpdatePaginatedDatasets();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void InitializeFilters()
    {
        _filterDefinitions = new()
        {
            new FilterDefinition
            {
                Key = "created",
                Label = "Created",
                Options = new() { "Today", "This Week", "This Month", "Older" }
            }
        };
    }

    private void OnFilterApplied(Dictionary<string, string> filters)
    {
        _filteredDatasets = _datasets;

        if (filters.ContainsKey("created"))
        {
            var now = DateTime.Now;
            _filteredDatasets = _filteredDatasets.Where(d =>
            {
                var uploaded = d.UploadedAt;
                return filters["created"] switch
                {
                    "Today" => uploaded.Date == now.Date,
                    "This Week" => (now - uploaded).TotalDays < 7,
                    "This Month" => (now - uploaded).TotalDays < 30,
                    "Older" => (now - uploaded).TotalDays >= 30,
                    _ => true
                };
            }).ToList();
        }

        _currentPage = 1;
        UpdatePaginatedDatasets();
    }

    private void OnPageChanged(int page)
    {
        _currentPage = page;
        UpdatePaginatedDatasets();
    }

    private void UpdatePaginatedDatasets()
    {
        var skip = (_currentPage - 1) * _pageSize;
        _paginatedDatasets = _filteredDatasets.Skip(skip).Take(_pageSize).ToList();
    }

    private async Task DeleteDatasetAsync(Guid datasetId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this dataset?"))
            return;

        var success = await DatasetApi.DeleteAsync(datasetId);
        if (success)
        {
            await LoadDatasets();
        }
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<style>
    .datasets-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .header-actions {
        margin-top: 16px;
    }

    .table-card {
        padding: 0;
        overflow: hidden;
    }

    .tw-table {
        width: 100%;
        border-collapse: collapse;
    }

    .tw-table th {
        text-align: left;
        padding: 16px 24px;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid var(--border-subtle);
        background: rgba(255, 255, 255, 0.01);
    }

    .tw-table td {
        padding: 16px 24px;
        font-size: 0.9rem;
        border-bottom: 1px solid var(--border-subtle);
    }

    .tw-table tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .dataset-name-cell {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
        color: var(--text-h1);
    }

    .dataset-icon {
        font-size: 1.2rem;
    }

    .tw-mono {
        font-family: var(--font-mono);
        color: var(--accent-cyan);
        background: rgba(34, 211, 238, 0.05);
        padding: 2px 6px;
        border-radius: 4px;
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .btn-xs {
        padding: 4px 12px !important;
        font-size: 0.75rem !important;
        height: 28px;
    }

    .empty-state {
        text-align: center;
        padding: 80px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(129, 140, 248, 0.1);
        border-top-color: var(--accent-violet);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto;
    }


    .filter-section {
        margin-bottom: -16px;
    }
</style>
