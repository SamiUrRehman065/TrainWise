@page "/training/train"
@page "/training"
@page "/train"
@inject TrainWise.Web.Services.Api.TrainingApi TrainingApi
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@using TrainWise.Web.Components.Common

<div class="training-page">
    <section class="tw-section-header">
        <h1 class="text-gradient">Train ML Model</h1>
        <p class="subtitle">Configure your preprocessing pipeline, select a model, and start training on your data.</p>
    </section>

    <div class="train-grid">
            <!-- MAIN CONFIGURATION -->
            <div class="train-main animate-fade-up">
                <div class="tw-card config-card">
                    <div class="config-section">
                        <h3><span class="section-icon">📁</span> Dataset Selection</h3>
                        <div class="form-group">
                            <label>Choose Dataset</label>
                            <select class="tw-input" @bind="_selectedDatasetId" @bind:after="OnDatasetSelected">
                                <option value="">-- Select a dataset --</option>
                                @if (_datasets?.Any() == true)
                                {
                                    @foreach (var dataset in _datasets)
                                    {
                                        <option value="@dataset.DatasetId">
                                            @dataset.Name (@dataset.RowCount rows)
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        @if (_selectedDataset is not null)
                        {
                            <div class="dataset-preview-grid">
                                <div class="tw-stat-card mini">
                                    <span class="stat-number small">@_selectedDataset.RowCount.ToString("N0")</span>
                                    <span class="stat-label">Rows</span>
                                </div>
                                <div class="tw-stat-card mini">
                                    <span class="stat-number small">@_selectedDataset.ColumnCount.ToString("N0")</span>
                                    <span class="stat-label">Columns</span>
                                </div>
                                <div class="tw-stat-card mini">
                                    <span class="stat-number small">@FormatBytes(_selectedDataset.Size)</span>
                                    <span class="stat-label">Size</span>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="config-section">
                        <h3><span class="section-icon">⚙️</span> Model Configuration</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Task Type</label>
                                <select class="tw-input" @bind="_request.TaskType" @bind:after="OnTaskTypeChanged">
                                    <option value="">-- Select Task --</option>
                                    <option value="classification">Classification</option>
                                    <option value="regression">Regression</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Model</label>
                                <select class="tw-input" @bind="_request.Model.Name">
                                    <option value="">-- Select Model --</option>
                                    @if (_request.TaskType == "classification")
                                    {
                                        <option value="LogisticRegression">Logistic Regression</option>
                                        <option value="RandomForest">Random Forest</option>
                                        <option value="SVM">SVM (Support Vector Machine)</option>
                                        <option value="KNN">KNN (K-Nearest Neighbors)</option>
                                        <option value="DecisionTree">Decision Tree</option>
                                        <option value="GradientBoosting">Gradient Boosting</option>
                                        <option value="AdaBoost">AdaBoost</option>
                                        <option value="NaiveBayes">Naive Bayes</option>
                                    }
                                    else if (_request.TaskType == "regression")
                                    {
                                        <option value="LinearRegression">Linear Regression</option>
                                        <option value="Ridge">Ridge Regression</option>
                                        <option value="Lasso">Lasso Regression</option>
                                        <option value="RandomForestRegressor">Random Forest Regressor</option>
                                        <option value="DecisionTree">Decision Tree Regressor</option>
                                        <option value="GradientBoosting">Gradient Boosting Regressor</option>
                                        <option value="SVR">SVR (Support Vector Regressor)</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- DYNAMIC HYPERPARAMETERS -->
                        @if (!string.IsNullOrEmpty(_request.Model.Name))
                        {
                            <div class="hyperparams-grid animate-fade-up">
                                @if (_request.Model.Name.Contains("RandomForest") || _request.Model.Name.Contains("GradientBoosting") || _request.Model.Name.Contains("AdaBoost"))
                                {
                                    <div class="form-group">
                                        <label>N Estimators (Trees)</label>
                                        <input type="number" class="tw-input" @bind="_request.Model.Hyperparameters.NEstimators" placeholder="Default: 100" />
                                    </div>
                                }
                                @if (_request.Model.Name.Contains("RandomForest") || _request.Model.Name.Contains("DecisionTree") || _request.Model.Name.Contains("Boosting"))
                                {
                                    <div class="form-group">
                                        <label>Max Depth</label>
                                        <input type="number" class="tw-input" @bind="_request.Model.Hyperparameters.MaxDepth" placeholder="Default: None" />
                                    </div>
                                }
                                @if (_request.Model.Name == "SVM" || _request.Model.Name == "SVR" || _request.Model.Name == "LogisticRegression")
                                {
                                    <div class="form-group">
                                        <label>C (Regularization)</label>
                                        <input type="number" step="0.1" class="tw-input" @bind="_request.Model.Hyperparameters.C" placeholder="Default: 1.0" />
                                    </div>
                                }
                                @if (_request.Model.Name == "SVM" || _request.Model.Name == "SVR")
                                {
                                    <div class="form-group">
                                        <label>Kernel</label>
                                        <select class="tw-input" @bind="_request.Model.Hyperparameters.Kernel">
                                            <option value="rbf">RBF</option>
                                            <option value="linear">Linear</option>
                                            <option value="poly">Polynomial</option>
                                        </select>
                                    </div>
                                }
                                @if (_request.Model.Name == "KNN")
                                {
                                    <div class="form-group">
                                        <label>K Neighbors</label>
                                        <input type="number" class="tw-input" @bind="_request.Model.Hyperparameters.NNeighbors" placeholder="Default: 5" />
                                    </div>
                                }
                                @if (_request.Model.Name == "Ridge" || _request.Model.Name == "Lasso")
                                {
                                    <div class="form-group">
                                        <label>Alpha (Regularization)</label>
                                        <input type="number" step="0.01" class="tw-input" @bind="_request.Model.Hyperparameters.Alpha" placeholder="Default: 1.0" />
                                    </div>
                                }

                                <!-- CUSTOM HYPERPARAMETERS -->
                                <div class="custom-params-section">
                                    <label class="section-label">Advanced Parameters</label>
                                    @foreach (var param in _request.Model.Hyperparameters.AdditionalParams.ToList())
                                    {
                                        <div class="custom-param-row animate-fade-up">
                                            <input type="text" class="tw-input sm" placeholder="Param Name" 
                                                   value="@param.Key" @onchange='(e) => UpdateParamKey(param.Key, e.Value?.ToString())' />
                                            <input type="text" class="tw-input sm" placeholder="Value" 
                                                   value="@param.Value" @onchange='(e) => UpdateParamValue(param.Key, e.Value)' />
                                            <button class="tw-btn-ghost sm text-danger" @onclick="() => RemoveParam(param.Key)">✕</button>
                                        </div>
                                    }
                                    <button class="tw-btn-ghost sm" @onclick="AddParam" style="margin-top: 8px;">+ Add Parameter</button>
                                </div>
                            </div>
                        }

                        <div class="form-group">
                            <label>Target Column (Variable to Predict)</label>
                            <select class="tw-input" @bind="_request.TargetColumn">
                                <option value="">-- Select target --</option>
                                @if (_columns?.Any() == true)
                                {
                                    @foreach (var col in _columns)
                                    {
                                        <option value="@col">@col</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="config-section">
                        <h3><span class="section-icon">🧪</span> Preprocessing & Validation</h3>
                        <div class="form-row thirds">
                            <div class="form-group">
                                <label>Scaling</label>
                                <select class="tw-input" @bind="_request.Preprocessing.Scaling">
                                    <option value="standard">Standard</option>
                                    <option value="minmax">MinMax</option>
                                    <option value="none">None</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Encoding</label>
                                <select class="tw-input" @bind="_request.Preprocessing.Encoding">
                                    <option value="onehot">One-hot</option>
                                    <option value="label">Label</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Null Strategy</label>
                                <select class="tw-input" @bind="_request.Preprocessing.NullStrategy">
                                    <option value="drop">Drop</option>
                                    <option value="mean">Mean</option>
                                    <option value="median">Median</option>
                                    <option value="mode">Mode</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-row thirds">
                            <div class="form-group">
                                <label>Train/Test Split</label>
                                <select class="tw-input" @bind="_request.TrainTestSplit">
                                    <option value="0.8">80 / 20</option>
                                    <option value="0.75">75 / 25</option>
                                    <option value="0.7">70 / 30</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Validation Method</label>
                                <select class="tw-input" @onchange='(e) => { _request.CrossValidation = e.Value?.ToString() == "cv"; }'>
                                    <option value="split">Hold-out Split</option>
                                    <option value="cv">K-Fold Cross-Validation</option>
                                </select>
                            </div>
                            @if (_request.CrossValidation)
                            {
                                <div class="form-group">
                                    <label>Number of Folds</label>
                                    <input type="number" class="tw-input" @bind="_request.KFolds" min="2" max="10" />
                                </div>
                            }
                        </div>

                        <div class="form-group checkbox-container">
                            <label class="tw-checkbox">
                                <input type="checkbox" @bind="_request.Preprocessing.ApplySmote" />
                                <span class="checkmark"></span>
                                <span>Apply SMOTE (Oversampling for imbalanced classes)</span>
                            </label>
                        </div>
                    </div>

                    <div class="train-actions">
                        <button class="tw-btn-primary" @onclick="TrainAsync" disabled="@(_isLoading || string.IsNullOrEmpty(_selectedDatasetId) || string.IsNullOrEmpty(_request.TaskType) || string.IsNullOrEmpty(_request.Model.Name) || string.IsNullOrEmpty(_request.TargetColumn))">
                            @if (_isLoading)
                            {
                                <span class="spinner-inline"></span>
                                <span>Training...</span>
                            }
                            else
                            {
                                <span>⚡ Start Training Job</span>
                            }
                        </button>
                        <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo("/experiments")'>
                            View History
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(_message))
                    {
                        var alertClass = _messageType switch
                        {
                            "success" => "success",
                            "error" => "danger",
                            "info" => "info",
                            _ => "info"
                        };
                        <div class="tw-badge @alertClass message-alert">
                            @_message
                        </div>
                    }
                </div>
            </div>

            <!-- SIDEBAR STATUS & TIPS -->
            <div class="train-sidebar animate-fade-up" style="animation-delay: 0.1s;">
                <div class="tw-card status-card">
                    <h3>Status</h3>
                    <div class="status-display">
                        @if (_isLoading)
                        {
                            <div class="status-indicator">
                                <div class="status-dot success"></div>
                                <span class="tw-badge info">Running Pipeline</span>
                            </div>
                            <div class="terminal-log">
                                <div class="log-line">> Initializing model architecture...</div>
                                <div class="log-line">> Loading dataset from storage...</div>
                                <div class="log-line">> Applying @_request.Preprocessing.Scaling scaling...</div>
                                <div class="log-line">> Training @_request.Model.Name...</div>
                                <div class="log-line blinking">_</div>
                            </div>
                        }
                        else if (_result is not null)
                        {
                            <div class="status-indicator">
                                <span class="tw-badge success">Completed Successfully</span>
                            </div>
                            <div class="result-summary">
                                <div class="summary-item">
                                    <label>@(_request.TaskType.Equals("classification", StringComparison.OrdinalIgnoreCase) ? "Accuracy" : "R² Score")</label>
                                    <span class="text-gradient">
                                        @(_request.TaskType.Equals("classification", StringComparison.OrdinalIgnoreCase) 
                                            ? (_result.ClassificationMetrics?.Accuracy.ToString("P1") ?? "N/A") 
                                            : (_result.RegressionMetrics?.R2Score.ToString("F3") ?? "N/A"))
                                    </span>
                                </div>
                                <button class="tw-btn-primary btn-full" @onclick='() => NavManager.NavigateTo($"/experiments/{_result.ExperimentId}")'>
                                    View Full Report
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="status-indicator">
                                <span class="tw-badge info">Idle</span>
                            </div>
                            <p class="text-muted">Configure your model and click "Start Training" to begin the process.</p>
                        }
                    </div>
                </div>

                <div class="tw-card tips-card">
                    <h3>Pro Tips</h3>
                    <ul class="tips-list">
                        <li><strong>Standard Scaling</strong> is recommended for most numerical models like SVM and KNN.</li>
                        <li>Use <strong>SMOTE</strong> if your target class distribution is more than 2:1 imbalanced.</li>
                        <li><strong>5-Fold CV</strong> provides a more robust estimate of model performance on unseen data.</li>
                        <li>Large datasets (>10k rows) may take up to 60 seconds to train.</li>
                    </ul>
                </div>
            </div>
        </div>
</div>

@code {
    private TrainWise.Web.Models.TrainRequest _request = new();
    private TrainWise.Web.Models.TrainResult? _result;
    private List<DatasetListItem>? _datasets;
    private DatasetListItem? _selectedDataset;
    private List<string>? _columns;
    private string _selectedDatasetId = string.Empty;
    private bool _isLoading = false;
    private string? _message;
    private string _messageType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        await LoadDatasets();
    }

    private async Task LoadDatasets()
    {
        var result = await DatasetApi.GetAllAsync();
        _datasets = result?.Items;
    }

    private async Task OnDatasetSelected()
    {
        _selectedDataset = null;
        _columns = null;
        _request.TargetColumn = string.Empty;
        _message = null;

        if (!string.IsNullOrEmpty(_selectedDatasetId) && Guid.TryParse(_selectedDatasetId, out var datasetId))
        {
            _selectedDataset = _datasets?.FirstOrDefault(d => d.DatasetId == datasetId);
            _request.DatasetId = _selectedDatasetId;

            _isLoading = true;
            try
            {
                // Get deep intelligence to auto-suggest task and target
                var intelligence = await DatasetApi.GetIntelligenceAsync(datasetId);
                if (intelligence?.Overview is not null)
                {
                    _columns = intelligence.Features.Select(f => f.Name).ToList();
                    
                    // Auto-suggest target
                    if (!string.IsNullOrEmpty(intelligence.Overview.TargetColumn))
                    {
                        _request.TargetColumn = intelligence.Overview.TargetColumn;
                    }

                    // Auto-suggest problem type
                    if (intelligence.Overview.ProblemType.Contains("Classification"))
                    {
                        _request.TaskType = "classification";
                        _request.Model.Name = "RandomForest";
                    }
                    else if (intelligence.Overview.ProblemType.Contains("Regression"))
                    {
                        _request.TaskType = "regression";
                        _request.Model.Name = "RandomForestRegressor";
                    }
                    
                    _message = $"System detected: {intelligence.Overview.ProblemType}. Configurations auto-applied.";
                    _messageType = "info";
                }
            }
            catch (Exception)
            {
                // Fallback to basic summary if intelligence fails
                var summary = await DatasetApi.GetSummaryAsync(datasetId);
                if (summary?.ColumnTypes is not null)
                {
                    _columns = summary.ColumnTypes.Keys.ToList();
                }
            }
            finally
            {
                _isLoading = false;
            }
        }
    }

    private Task OnTaskTypeChanged()
    {
        _request.Model.Name = string.Empty;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task TrainAsync()
    {
        if (string.IsNullOrEmpty(_selectedDatasetId) || string.IsNullOrEmpty(_request.TaskType) ||
            string.IsNullOrEmpty(_request.Model.Name) || string.IsNullOrEmpty(_request.TargetColumn))
        {
            _message = "Please fill in all required fields.";
            _messageType = "error";
            return;
        }

        _isLoading = true;
        _message = null;
        _result = null;

        _result = await TrainingApi.TrainAsync(_request);

        if (_result is not null)
        {
            _message = "Training completed successfully.";
            _messageType = "success";
        }
        else
        {
            _message = "Training failed. Check your configuration and try again.";
            _messageType = "error";
        }

        _isLoading = false;
    }

    private void AddParam()
    {
        var key = $"param_{_request.Model.Hyperparameters.AdditionalParams.Count + 1}";
        _request.Model.Hyperparameters.AdditionalParams[key] = "";
        StateHasChanged();
    }

    private void RemoveParam(string key)
    {
        _request.Model.Hyperparameters.AdditionalParams.Remove(key);
        StateHasChanged();
    }

    private void UpdateParamKey(string oldKey, string? newKey)
    {
        if (string.IsNullOrWhiteSpace(newKey) || _request.Model.Hyperparameters.AdditionalParams.ContainsKey(newKey)) return;
        
        var val = _request.Model.Hyperparameters.AdditionalParams[oldKey];
        _request.Model.Hyperparameters.AdditionalParams.Remove(oldKey);
        _request.Model.Hyperparameters.AdditionalParams[newKey] = val;
    }

    private void UpdateParamValue(string key, object? value)
    {
        if (value == null) return;
        _request.Model.Hyperparameters.AdditionalParams[key] = value;
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<style>
    .training-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .train-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 32px;
        align-items: start;
    }

    .config-card {
        display: flex;
        flex-direction: column;
        gap: 40px;
    }

    .config-section h3 {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        font-size: 1.25rem;
    }

    .section-icon {
        font-size: 1.5rem;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .hyperparams-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
        padding: 24px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        margin: 20px 0;
    }

    .custom-params-section {
        grid-column: 1 / -1;
        border-top: 1px solid var(--border-subtle);
        padding-top: 20px;
        margin-top: 10px;
    }

    .section-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 16px;
        letter-spacing: 1px;
    }

    .custom-param-row {
        display: grid;
        grid-template-columns: 1fr 1fr 40px;
        gap: 12px;
        margin-bottom: 12px;
    }

    .tw-input.sm {
        padding: 8px 12px;
        font-size: 0.85rem;
    }

    .form-row.thirds {
        grid-template-columns: 1fr 1fr 1fr;
    }

    .dataset-preview-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-top: 16px;
    }

    .tw-stat-card.mini {
        padding: 12px 16px;
    }

    .stat-number.small {
        font-size: 1.25rem;
    }

    .tw-checkbox {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        font-size: 0.95rem;
        color: var(--text-body);
    }

    .train-actions {
        display: flex;
        gap: 16px;
        padding-top: 24px;
        border-top: 1px solid var(--border-subtle);
    }

    .message-alert {
        padding: 12px 20px;
        width: 100%;
        justify-content: center;
    }

    .train-sidebar {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .status-display {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        animation: pulse-dot 1.5s infinite;
    }

    .status-dot.success { background: var(--accent-green); box-shadow: 0 0 10px var(--accent-green); }

    .terminal-log {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        padding: 16px;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-body);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .log-line {
        opacity: 0.8;
    }

    .blinking {
        animation: fadeIn 0.8s infinite alternate;
        color: var(--accent-violet);
    }

    .result-summary {
        background: var(--bg-elevated);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .summary-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .summary-item label {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 600;
    }

    .summary-item span {
        font-size: 1.5rem;
        font-weight: 800;
    }

    .btn-full {
        width: 100%;
        justify-content: center;
    }

    .tips-list {
        padding-left: 20px;
        margin: 0;
    }

    .tips-list li {
        margin-bottom: 12px;
        font-size: 0.85rem;
        line-height: 1.6;
        color: var(--text-body);
    }

    .tips-list li strong {
        color: var(--text-h1);
    }

    .spinner-inline {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@media (max-width: 1024px) {
        .train-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
