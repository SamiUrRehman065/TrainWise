@page "/results/{ExperimentId:guid}"
@inject IJSRuntime JSRuntime
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject ILogger<Metrics> Logger
@using TrainWise.Web.Components.Common
@using TrainWise.Web.Components.Charts

<div class="metrics-page animate-fade-up">
    @if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 80px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Calculating Performance Vectors...</p>
        </div>
    }
    else if (_experiment is null)
    {
        <div class="tw-card empty-state">
            <div class="empty-icon">🔎</div>
            <h3>Results Not Found</h3>
            <p class="subtitle">We couldn't retrieve metrics for this specific session.</p>
            <button class="tw-btn-primary" style="margin-top: 24px;" @onclick='() => NavManager.NavigateTo("/metrics")'>Back to Metrics Hub</button>
        </div>
    }
    else
    {
        <section class="tw-section-header">
            <h1 class="text-gradient">Metrics: @_experiment.ModelName</h1>
            <p class="subtitle">Detailed performance evaluation for the @_experiment.TaskType model.</p>
            <div class="header-actions">
                <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo($"/experiments/{ExperimentId}")'>📜 View Details</button>
            </div>
        </section>

        @if (_experiment.Metrics is not null)
        {
            <!-- PRIMARY SCORES -->
            <div class="metrics-scores-grid animate-fade-up">
                <div class="tw-stat-card">
                    <span class="stat-label">Accuracy</span>
                    <span class="stat-number">@(_experiment.Metrics.Accuracy.ToString("P1"))</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-label">Precision</span>
                    <span class="stat-number">@(_experiment.Metrics.Precision.ToString("F2"))</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-label">Recall</span>
                    <span class="stat-number">@(_experiment.Metrics.Recall.ToString("F2"))</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-label">F1-Score</span>
                    <span class="stat-number">@(_experiment.Metrics.F1Score.ToString("F2"))</span>
                </div>
            </div>

            <div class="detailed-analysis-grid">
                <!-- CONFUSION MATRIX -->
                @if (_experiment.Charts != null)
                {
                    <section class="visualization-section animate-fade-up" style="animation-delay: 0.1s; margin-top: 40px;">
                        <div class="section-header">
                            <h3>📊 Advanced Performance Analytics</h3>
                            <p class="subtitle">Deep-dive diagnostics for the @_experiment.ModelName model.</p>
                        </div>

                        @if (_experiment.TaskType.Equals("classification", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="chart-grid">
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Confusion Matrix</span></div>
                                    <div id="chart-confusion-matrix" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>ROC Curve</span></div>
                                    <div id="chart-roc-curve" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Precision-Recall Curve</span></div>
                                    <div id="chart-pr-curve" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Confidence Distribution</span></div>
                                    <div id="chart-prob-dist" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Class Comparison</span></div>
                                    <div id="chart-class-comp" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Feature Importance</span></div>
                                    <div id="chart-feat-imp-cls" class="plotly-container"></div>
                                </div>
                            </div>
                        }
                        else if (_experiment.TaskType.Equals("regression", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="chart-grid">
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Actual vs Predicted</span></div>
                                    <div id="chart-actual-pred" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Residuals Plot</span></div>
                                    <div id="chart-residuals-scatter" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Error Distribution</span></div>
                                    <div id="chart-residuals-dist" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Q-Q Plot</span></div>
                                    <div id="chart-qq-plot" class="plotly-container"></div>
                                </div>
                                <div class="tw-card chart-card">
                                    <div class="chart-header"><span>Feature Importance</span></div>
                                    <div id="chart-feat-imp-reg" class="plotly-container"></div>
                                </div>
                            </div>
                        }

                        @if (_experiment.Charts.CrossValidation != null)
                        {
                            <div class="chart-grid" style="margin-top: 24px;">
                                <div class="tw-card chart-card" style="grid-column: span 2; min-height: 350px;">
                                    <div class="chart-header">
                                        <span>Cross-Validation Stability</span>
                                        <span class="tw-badge success">Mean: @(_experiment.Charts.CrossValidation.Mean.ToString("F3"))</span>
                                    </div>
                                    <div id="chart-cv-variance" class="plotly-container"></div>
                                </div>
                            </div>
                        }
                    </section>
                }
                else if (_experiment.Metrics.ConfusionMatrix is not null)
                {
                    <div class="tw-card matrix-container animate-fade-up" style="animation-delay: 0.1s;">
                        <h3>📊 Confusion Matrix</h3>
                        <p class="section-desc">Visualizing the relationship between actual and predicted classes.</p>
                        <div class="chart-wrapper">
                            <ConfusionMatrix Matrix="@_experiment.Metrics.ConfusionMatrix" />
                        </div>
                    </div>
                }

                <!-- CLASSIFICATION REPORT -->
                @if (_experiment.Metrics.ClassificationReport is not null)
                {
                    <div class="tw-card report-container animate-fade-up" style="animation-delay: 0.2s;">
                        <h3>📄 Classification Report</h3>
                        <p class="section-desc">Per-class breakdown of performance metrics.</p>
                        <div class="tw-table-wrapper">
                            <table class="tw-table">
                                <thead>
                                    <tr>
                                        <th>Class</th>
                                        <th>Precision</th>
                                        <th>Recall</th>
                                        <th>F1-score</th>
                                        <th>Support</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in _experiment.Metrics.ClassificationReport)
                                    {
                                        <tr>
                                            <td class="tw-font-bold">@entry.Key</td>
                                            <td class="tw-mono">@(entry.Value?.Precision.ToString("F2") ?? "-")</td>
                                            <td class="tw-mono">@(entry.Value?.Recall.ToString("F2") ?? "-")</td>
                                            <td class="tw-mono">@(entry.Value?.F1Score.ToString("F2") ?? "-")</td>
                                            <td class="tw-muted">@(entry.Value?.Support)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="tw-card empty-state">
                <div class="empty-icon">📊</div>
                <h3>No Metrics Computed</h3>
                <p class="subtitle">This training run completed without generating standard performance metrics.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid ExperimentId { get; set; }
    private ExperimentDetail? _experiment;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        await LoadMetrics();
    }

    private async Task LoadMetrics()
    {
        try
        {
            _experiment = await ExperimentApi.GetAsync(ExperimentId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading experiment metrics");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool _chartsRendered = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_experiment?.Charts != null && !_chartsRendered)
        {
            _chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task RenderChartsAsync()
    {
        try
        {
            if (_experiment?.Charts == null) return;

            if (_experiment.TaskType.Equals("classification", StringComparison.OrdinalIgnoreCase))
            {
                if (_experiment.Charts.ConfusionMatrix != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderConfusionMatrix", "chart-confusion-matrix", _experiment.Charts.ConfusionMatrix);
                
                if (_experiment.Charts.RocCurve != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderRocCurve", "chart-roc-curve", _experiment.Charts.RocCurve);
                
                if (_experiment.Charts.PrecisionRecall != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderPrecisionRecall", "chart-pr-curve", _experiment.Charts.PrecisionRecall);
                
                if (_experiment.Charts.ProbabilityDist != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderProbabilityDist", "chart-prob-dist", _experiment.Charts.ProbabilityDist);

                if (_experiment.Charts.ClassComparison != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderClassComparison", "chart-class-comp", _experiment.Charts.ClassComparison);

                if (_experiment.Charts.FeatureImportance != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderFeatureImportance", "chart-feat-imp-cls", _experiment.Charts.FeatureImportance);
                
                if (_experiment.Charts.CrossValidation != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderCrossValidation", "chart-cv-variance", _experiment.Charts.CrossValidation);
            }
            else if (_experiment.TaskType.Equals("regression", StringComparison.OrdinalIgnoreCase))
            {
                if (_experiment.Charts.ActualVsPredicted != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderActualVsPredicted", "chart-actual-pred", _experiment.Charts.ActualVsPredicted);
                
                if (_experiment.Charts.ResidualsScatter != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderResidualsScatter", "chart-residuals-scatter", _experiment.Charts.ResidualsScatter);
                
                if (_experiment.Charts.ResidualsDistribution != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderResidualsDistribution", "chart-residuals-dist", _experiment.Charts.ResidualsDistribution);
                
                if (_experiment.Charts.QqPlot != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderQqPlot", "chart-qq-plot", _experiment.Charts.QqPlot);

                if (_experiment.Charts.FeatureImportance != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderFeatureImportance", "chart-feat-imp-reg", _experiment.Charts.FeatureImportance);

                if (_experiment.Charts.CrossValidation != null)
                    await JSRuntime.InvokeVoidAsync("TrainWiseCharts.renderCrossValidation", "chart-cv-variance", _experiment.Charts.CrossValidation);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error rendering charts on Metrics page");
        }
    }
}

<style>
    .metrics-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
        padding-bottom: 60px;
    }

    .metrics-scores-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .detailed-analysis-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
    }

    /* CHART STYLES */
    .visualization-section {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .chart-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
    }

    .chart-card {
        padding: 24px;
        min-height: 400px;
        display: flex;
        flex-direction: column;
    }

    .chart-header {
        margin-bottom: 16px;
        font-weight: 600;
        color: var(--text-h1);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .plotly-container {
        flex: 1;
        width: 100%;
        min-height: 300px;
    }

    .matrix-container, .report-container {
        padding: 40px;
    }

    .matrix-container h3, .report-container h3 {
        font-size: 1.25rem;
        color: var(--text-h1);
        margin-bottom: 8px;
    }

    .section-desc {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 32px;
    }

    .chart-wrapper {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 20px;
        padding: 20px;
        border: 1px solid var(--border-subtle);
    }

    .tw-font-bold { font-weight: 700; color: var(--text-h1); }

    @@media (max-width: 1024px) {
        .metrics-scores-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 600px) {
        .metrics-scores-grid { grid-template-columns: 1fr; }
    }
</style>
