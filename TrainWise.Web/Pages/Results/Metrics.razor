@page "/results/{ExperimentId:guid}"
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject ILogger<Metrics> Logger
@using TrainWise.Web.Components.Common
@using TrainWise.Web.Components.Charts

<div class="metrics-page animate-fade-up">
    @if (!SessionState.IsAuthenticated)
    {
        <div class="tw-card">
            <p>Please <a href="/login">sign in</a> to view performance metrics.</p>
        </div>
    }
    else if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 80px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Calculating Performance Vectors...</p>
        </div>
    }
    else if (_experiment is null)
    {
        <div class="tw-card empty-state">
            <div class="empty-icon">🔎</div>
            <h3>Results Not Found</h3>
            <p class="subtitle">We couldn't retrieve metrics for this specific session.</p>
            <button class="tw-btn-primary" style="margin-top: 24px;" @onclick='() => NavManager.NavigateTo("/metrics")'>Back to Metrics Hub</button>
        </div>
    }
    else
    {
        <section class="tw-section-header">
            <h1 class="text-gradient">Metrics: @_experiment.ModelName</h1>
            <p class="subtitle">Detailed performance evaluation for the @_experiment.TaskType model.</p>
            <div class="header-actions">
                <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo($"/experiments/{ExperimentId}")'>📜 View Details</button>
            </div>
        </section>

        @if (_experiment.Metrics is not null)
        {
            <!-- PRIMARY SCORES -->
            <div class="metrics-scores-grid animate-fade-up">
                <div class="tw-stat-card">
                    <span class="stat-label">Accuracy</span>
                    <span class="stat-number">@(_experiment.Metrics.Accuracy.ToString("P1"))</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-label">Precision</span>
                    <span class="stat-number">@(_experiment.Metrics.Precision.ToString("F2"))</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-label">Recall</span>
                    <span class="stat-number">@(_experiment.Metrics.Recall.ToString("F2"))</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-label">F1-Score</span>
                    <span class="stat-number">@(_experiment.Metrics.F1Score.ToString("F2"))</span>
                </div>
            </div>

            <div class="detailed-analysis-grid">
                <!-- CONFUSION MATRIX -->
                @if (_experiment.Metrics.ConfusionMatrix is not null)
                {
                    <div class="tw-card matrix-container animate-fade-up" style="animation-delay: 0.1s;">
                        <h3>📊 Confusion Matrix</h3>
                        <p class="section-desc">Visualizing the relationship between actual and predicted classes.</p>
                        <div class="chart-wrapper">
                            <ConfusionMatrix Matrix="@_experiment.Metrics.ConfusionMatrix" />
                        </div>
                    </div>
                }

                <!-- CLASSIFICATION REPORT -->
                @if (_experiment.Metrics.ClassificationReport is not null)
                {
                    <div class="tw-card report-container animate-fade-up" style="animation-delay: 0.2s;">
                        <h3>📄 Classification Report</h3>
                        <p class="section-desc">Per-class breakdown of performance metrics.</p>
                        <div class="tw-table-wrapper">
                            <table class="tw-table">
                                <thead>
                                    <tr>
                                        <th>Class</th>
                                        <th>Precision</th>
                                        <th>Recall</th>
                                        <th>F1-score</th>
                                        <th>Support</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in _experiment.Metrics.ClassificationReport)
                                    {
                                        <tr>
                                            <td class="tw-font-bold">@entry.Key</td>
                                            <td class="tw-mono">@(entry.Value?.Precision.ToString("F2") ?? "-")</td>
                                            <td class="tw-mono">@(entry.Value?.Recall.ToString("F2") ?? "-")</td>
                                            <td class="tw-mono">@(entry.Value?.F1Score.ToString("F2") ?? "-")</td>
                                            <td class="tw-muted">@(entry.Value?.Support)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="tw-card empty-state">
                <div class="empty-icon">📊</div>
                <h3>No Metrics Computed</h3>
                <p class="subtitle">This training run completed without generating standard performance metrics.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid ExperimentId { get; set; }
    private ExperimentDetail? _experiment;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadMetrics();
    }

    private async Task LoadMetrics()
    {
        try
        {
            _experiment = await ExperimentApi.GetAsync(ExperimentId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading experiment metrics");
        }
        finally
        {
            _isLoading = false;
        }
    }
}

<style>
    .metrics-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
        padding-bottom: 60px;
    }

    .metrics-scores-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .detailed-analysis-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
    }

    .matrix-container, .report-container {
        padding: 40px;
    }

    .matrix-container h3, .report-container h3 {
        font-size: 1.25rem;
        color: var(--text-h1);
        margin-bottom: 8px;
    }

    .section-desc {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 32px;
    }

    .chart-wrapper {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 20px;
        padding: 20px;
        border: 1px solid var(--border-subtle);
    }

    .tw-font-bold { font-weight: 700; color: var(--text-h1); }

    @@media (max-width: 1024px) {
        .metrics-scores-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 600px) {
        .metrics-scores-grid { grid-template-columns: 1fr; }
    }
</style>
