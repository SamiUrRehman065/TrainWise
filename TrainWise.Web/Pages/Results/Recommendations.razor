@page "/results/{ExperimentId:guid}/recommendations"
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@using TrainWise.Web.Components.Common

<div class="recommendations-page">
    @if (!SessionState.IsAuthenticated)
    {
        <div class="tw-card animate-fade-up">
            <p>Please <a href="/login">sign in</a> to view insights.</p>
        </div>
    }
    else if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 60px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Running Diagnostic Engine...</p>
        </div>
    }
    else if (_experiment is null)
    {
        <div class="tw-card empty-state animate-fade-up">
            <div class="empty-icon">🔍</div>
            <h3>Experiment Not Found</h3>
            <p class="subtitle">The model run you're analyzing could not be loaded.</p>
            <button class="tw-btn-primary" style="margin-top: 24px;" @onclick='() => NavManager.NavigateTo("/experiments")'>Back to History</button>
        </div>
    }
    else
    {
        <section class="tw-section-header animate-fade-up">
            <h1 class="text-gradient">Model Insights</h1>
            <p class="subtitle">AI-driven recommendations and performance diagnostics for <strong>@_experiment.ModelName</strong>.</p>
            <div class="header-actions">
                <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo($"/experiments/{ExperimentId}")'>📜 View Details</button>
                <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/training")'>🔄 Retrain Model</button>
            </div>
        </section>

        <!-- DIAGNOSTIC VISUALS -->
        @if (_experiment?.Result?.ClassificationMetrics != null || _experiment?.Result?.RegressionMetrics != null)
        {
            <div class="diagnostics-grid animate-fade-up">
                <div class="tw-card diagnostic-card">
                    <h3>🎯 Bias vs Variance (Overfitting)</h3>
                    <div class="diagnostic-viz">
                        @{
                            var result = _experiment.Result;
                            if (result?.ClassificationMetrics != null)
                            {
                                var classMetrics = result.ClassificationMetrics;
                                @RenderDiagnosticBar("Train Accuracy", classMetrics.TrainAccuracy ?? 0, "var(--accent-violet)")
                                @RenderDiagnosticBar("Test Accuracy", classMetrics.Accuracy, "var(--accent-cyan)")
                            }
                            else if (result?.RegressionMetrics != null)
                            {
                                var regMetrics = result.RegressionMetrics;
                                @RenderDiagnosticBar("Train R²", Math.Max(0, regMetrics.TrainR2 ?? 0), "var(--accent-violet)")
                                @RenderDiagnosticBar("Test R²", Math.Max(0, regMetrics.R2Score), "var(--accent-cyan)")
                            }
                        }
                    </div>
                </div>

                <div class="tw-card diagnostic-card">
                    <h3>⚖️ Balance & Stability</h3>
                    <div class="diagnostic-viz">
                        @{
                            var res2 = _experiment.Result;
                            if (res2?.ClassificationMetrics != null)
                            {
                                var classMetrics = res2.ClassificationMetrics;
                                @RenderDiagnosticBar("Precision", classMetrics.Precision, "var(--accent-green)")
                                @RenderDiagnosticBar("Recall", classMetrics.Recall, "#facc15")
                            }
                            else if (res2?.RegressionMetrics != null)
                            {
                                var regMetrics = res2.RegressionMetrics;
                                @RenderDiagnosticBar("RMSE Error", Math.Min(1, regMetrics.Rmse / 100), "var(--accent-red)")
                                @RenderDiagnosticBar("MAE Error", Math.Min(1, regMetrics.Mae / 100), "#facc15")
                            }
                        }
                    </div>
                </div>
            </div>
        }

        <!-- RECOMMENDATIONS LIST -->
        <div class="recommendations-section animate-fade-up">
            <h3>🚨 Suggested Actions</h3>
            @if (_recommendations.Count == 0)
            {
                <div class="tw-card success-card">
                    <span class="success-icon">✅</span>
                    <p>No optimization issues detected. Your model configuration appears optimal for this dataset.</p>
                </div>
            }
            else
            {
                <div class="rec-list">
                    @foreach (var rec in _recommendations)
                    {
                        <div class="tw-card rec-card @GetSeverityClass(rec.Severity)">
                            <div class="rec-header">
                                <span class="tw-badge @GetBadgeClass(rec.Severity)">@GetSeverityLabel(rec.Severity)</span>
                            </div>
                            <p class="rec-message">@rec.Message</p>
                            @if (!string.IsNullOrEmpty(rec.Action))
                            {
                                <div class="action-box">
                                    <span class="action-label">Recommendation:</span>
                                    <span class="action-text">@rec.Action</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- DATA QUALITY -->
        @if (_datasetSummary is not null)
        {
            <div class="quality-section animate-fade-up">
                <h3>📊 Underlying Data Quality</h3>
                <div class="quality-grid">
                    <div class="tw-stat-card">
                        <span class="stat-label">Dataset Rows</span>
                        <span class="stat-number">@_datasetSummary.RowCount.ToString("N0")</span>
                    </div>
                    <div class="tw-stat-card">
                        <span class="stat-label">Total Features</span>
                        <span class="stat-number">@_datasetSummary.ColumnCount</span>
                    </div>
                    <div class="tw-stat-card @(_datasetSummary.ImbalanceRatio > 2 ? "warning-border" : "")">
                        <span class="stat-label">Imbalance Ratio</span>
                        <span class="stat-number">@_datasetSummary.ImbalanceRatio?.ToString("0.00")</span>
                    </div>
                    <div class="tw-stat-card">
                        <span class="stat-label">Missing Data</span>
                        <span class="stat-number">@_totalMissing</span>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid ExperimentId { get; set; }
    private ExperimentDetail? _experiment;
    private DatasetSummary? _datasetSummary;
    private List<TrainWise.Web.Models.Recommendation> _recommendations = new();
    private bool _isLoading = true;
    private int _totalMissing;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _experiment = await ExperimentApi.GetAsync(ExperimentId);
            if (_experiment is null) return;

            _datasetSummary = await DatasetApi.GetSummaryAsync(_experiment.DatasetId);
            if (_datasetSummary is not null)
                _totalMissing = _datasetSummary.MissingValues.Values.Sum(m => m.Count);

            var apiRecs = await ExperimentApi.GetRecommendationsAsync(ExperimentId);
            if (apiRecs is not null) _recommendations = apiRecs;
        }
        catch { }
        finally { _isLoading = false; }
    }

    private string GetSeverityClass(string severity) => severity.ToLower() == "critical" ? "critical-card" : "";
    private string GetBadgeClass(string severity) => severity.ToLower() switch {
        "critical" => "danger",
        "warning" => "warning",
        "success" => "success",
        _ => "info"
    };
    private string GetSeverityLabel(string severity) => severity.ToLower() switch {
        "critical" => "Critical Issue",
        "warning" => "Optimization Needed",
        "success" => "Optimal",
        _ => "Observation"
    };

    private RenderFragment RenderDiagnosticBar(string label, double value, string color) => @<div class="diag-bar-row">
        <div class="diag-label">
            <span>@label</span>
            <span class="tw-mono">@value.ToString("P1")</span>
        </div>
        <div class="tw-progress-bar">
            <div class="progress-fill" style="width: @((value * 100).ToString("F1"))%; background: @color;"></div>
        </div>
    </div>;
}

<style>
    .recommendations-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .diagnostics-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .diagnostic-card h3 {
        font-size: 1.1rem;
        margin-bottom: 24px;
        color: var(--text-h1);
    }

    .diagnostic-viz {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .diag-bar-row {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .diag-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: var(--text-body);
    }

    .recommendations-section h3, .quality-section h3 {
        font-size: 1.2rem;
        margin-bottom: 24px;
        color: var(--text-h1);
    }

    .rec-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .rec-card {
        border-left: 4px solid var(--accent-violet);
        padding: 24px;
    }

    .rec-card.critical-card {
        border-left-color: var(--accent-red);
        background: rgba(239, 68, 68, 0.03);
    }

    .rec-header { margin-bottom: 12px; }

    .rec-message {
        font-size: 1rem;
        color: var(--text-h1);
        font-weight: 500;
        margin-bottom: 16px;
        line-height: 1.6;
    }

    .action-box {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .action-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .action-text { font-size: 0.9rem; color: var(--text-body); }

    .success-card {
        text-align: center;
        padding: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
    }

    .success-icon { font-size: 3rem; }

    .quality-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .warning-border { border-color: #facc15 !important; }

    @@media (max-width: 1024px) {
        .diagnostics-grid { grid-template-columns: 1fr; }
        .quality-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>
