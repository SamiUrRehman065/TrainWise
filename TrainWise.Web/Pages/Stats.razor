@page "/stats"
@page "/dashboard"
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject ILogger<Stats> Logger
@inject NavigationManager NavManager
@using TrainWise.Web.Components.Common

<div class="dashboard-page animate-fade-up">
    <section class="tw-section-header">
        <h1 class="text-gradient">Workspace Dashboard</h1>
        <p class="subtitle">Real-time overview of your ML assets, training performance, and storage utilization.</p>
    </section>

    @if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 80px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Synchronizing Workspace...</p>
        </div>
    }
    else if (_stats is not null)
    {
        <!-- TOP METRICS -->
        <div class="stats-grid">
            <div class="tw-stat-card animate-fade-up" style="animation-delay: 0.1s;">
                <span class="stat-label">Total Datasets</span>
                <span class="stat-number">@_stats.TotalDatasets</span>
                <div class="stat-trend success">Active: @_stats.ActiveDatasets</div>
            </div>
            <div class="tw-stat-card animate-fade-up" style="animation-delay: 0.2s;">
                <span class="stat-label">Experiments Run</span>
                <span class="stat-number">@_stats.TotalExperiments</span>
                <div class="stat-trend info">History Tracked</div>
            </div>
            <div class="tw-stat-card animate-fade-up" style="animation-delay: 0.3s;">
                <span class="stat-label">Storage Mode</span>
                <span class="stat-number" style="font-size: 1.5rem;">@_stats.StorageMode</span>
                <div class="stat-trend warning">Local Disk</div>
            </div>
            <div class="tw-stat-card animate-fade-up" style="animation-delay: 0.4s;">
                <span class="stat-label">Space Used</span>
                <span class="stat-number">@FormatSize(_stats.EstimatedSize)</span>
                <div class="stat-trend">Approx. Size</div>
            </div>
        </div>

        <div class="dashboard-main-grid">
            <!-- QUICK ACTIONS -->
            <div class="actions-column">
                <div class="tw-card action-section animate-fade-up" style="animation-delay: 0.5s;">
                    <h3>⚡ Quick Actions</h3>
                    <div class="action-buttons-vertical">
                        <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/training")'>
                            <span>🚀 Train New Model</span>
                        </button>
                        <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo("/upload")'>
                            <span>📁 Upload Dataset</span>
                        </button>
                        <button class="tw-btn-ghost" @onclick="ArchiveDatasetsAsync">
                            <span>🧹 Archive Old Data</span>
                        </button>
                    </div>
                </div>

                <div class="tw-card nav-section animate-fade-up" style="animation-delay: 0.6s;">
                    <h3>🔗 Quick Navigation</h3>
                    <div class="nav-links-grid">
                        <a href="/datasets" class="nav-item">Datasets</a>
                        <a href="/experiments" class="nav-item">History</a>
                        <a href="/profile" class="nav-item">Profile</a>
                        <a href="/settings" class="nav-item">Settings</a>
                    </div>
                </div>
            </div>

            <!-- RECENT RUNS -->
            <div class="history-column">
                <div class="tw-card recent-runs animate-fade-up" style="animation-delay: 0.7s;">
                    <div class="section-header-inline">
                        <h3>📈 Recent Training History</h3>
                        <a href="/experiments" class="text-link">View All →</a>
                    </div>

                    @if (_trainingHistory?.Any() == true)
                    {
                        <div class="run-list">
                            @foreach (var run in _trainingHistory.Take(5))
                            {
                                <div class="run-item" @onclick='() => NavManager.NavigateTo($"/experiments/{run.ExperimentId}")'>
                                    <div class="run-icon">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                    </div>
                                    <div class="run-details">
                                        <div class="run-name">@run.ModelName</div>
                                        <div class="run-meta">
                                            <span class="tw-badge info">@run.TaskType</span>
                                            <span>&bull; @run.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                        </div>
                                    </div>
                                    <div class="run-duration tw-mono">
                                        @(run.TrainingDurationSec?.ToString("0.0") ?? "N/A")s
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-list">
                            <p>No training history yet. Start your first session!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="tw-badge @(_messageType == "success" ? "success" : "danger") full-width animate-fade-up">
                @_message
            </div>
        }
    }
</div>

@code {
    private DashboardStats? _stats;
    private List<TrainingHistoryItem>? _trainingHistory;
    private bool _isLoading = true;
    private string? _message;
    private string _messageType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        try
        {
            _stats = await DatasetApi.GetStatsAsync();
            var historyResponse = await ExperimentApi.GetTrainingHistoryAsync();
            _trainingHistory = historyResponse?.TrainingHistory;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dashboard data");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{(bytes / 1024.0):F1} KB";
        return $"{(bytes / (1024.0 * 1024.0)):F1} MB";
    }

    private async Task ArchiveDatasetsAsync()
    {
        try
        {
            var success = await DatasetApi.ArchiveAsync(30);
            if (success)
            {
                _message = "Older datasets archived successfully.";
                _messageType = "success";
                await LoadDashboardData();
            }
            else
            {
                _message = "No datasets qualified for archival.";
                _messageType = "info";
            }
        }
        catch (Exception ex)
        {
            _message = $"Archival failed: {ex.Message}";
            _messageType = "error";
        }
    }
}

<style>
    .dashboard-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .stat-trend {
        font-size: 0.75rem;
        margin-top: 8px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.8;
    }

    .stat-trend.success { color: var(--accent-green); }
    .stat-trend.info { color: var(--accent-cyan); }
    .stat-trend.warning { color: var(--accent-red); }

    .dashboard-main-grid {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 32px;
    }

    .actions-column {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .action-section h3, .nav-section h3, .recent-runs h3 {
        font-size: 1.1rem;
        margin-bottom: 24px;
        color: var(--text-h1);
    }

    .action-buttons-vertical {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .action-buttons-vertical button {
        width: 100%;
        justify-content: flex-start;
        padding-left: 20px;
    }

    .nav-links-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .nav-item {
        padding: 12px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        text-align: center;
        text-decoration: none;
        color: var(--text-body);
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .nav-item:hover {
        background: rgba(129, 140, 248, 0.1);
        border-color: var(--accent-violet);
        color: var(--text-h1);
        transform: translateY(-2px);
    }

    .recent-runs {
        padding: 40px;
    }

    .section-header-inline {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .text-link {
        font-size: 0.85rem;
        color: var(--accent-violet);
        font-weight: 700;
        text-decoration: none;
    }

    .run-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .run-item {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 16px 20px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border-subtle);
        border-radius: 16px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .run-item:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: var(--border-active);
        transform: translateX(4px);
    }

    .run-icon {
        color: var(--accent-violet);
        opacity: 0.8;
    }

    .run-details {
        flex: 1;
    }

    .run-name {
        font-weight: 700;
        color: var(--text-h1);
        font-size: 1rem;
        margin-bottom: 4px;
    }

    .run-meta {
        font-size: 0.8rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .run-duration {
        font-size: 0.9rem;
        color: var(--accent-cyan);
        font-weight: 700;
    }

    .full-width { width: 100%; justify-content: center; margin-top: 16px; }

    @@media (max-width: 1100px) {
        .dashboard-main-grid { grid-template-columns: 1fr; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 600px) {
        .stats-grid { grid-template-columns: 1fr; }
    }
</style>
