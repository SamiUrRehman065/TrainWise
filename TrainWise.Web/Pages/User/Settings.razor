@page "/settings"
@inject TrainWise.Web.Services.Api.UserApi UserApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@using TrainWise.Web.Components.Common
@using TrainWise.Web.Models

<div class="settings-page animate-fade-up">
    <section class="tw-section-header">
        <h1 class="text-gradient">Settings</h1>
        <p class="subtitle">Customize your workspace environment and security protocols.</p>
    </section>

    <div class="settings-layout">
            <aside class="settings-sidebar">
                <nav class="settings-nav">
                    <button class="nav-item @(_activeTab == "general" ? "active" : "")" @onclick='() => SetTab("general")'>
                        <span class="nav-icon">⚙️</span> General
                    </button>
                    <button class="nav-item @(_activeTab == "security" ? "active" : "")" @onclick='() => SetTab("security")'>
                        <span class="nav-icon">🛡️</span> Security
                    </button>
                    <button class="nav-item @(_activeTab == "storage" ? "active" : "")" @onclick='() => SetTab("storage")'>
                        <span class="nav-icon">💾</span> Storage
                    </button>
                </nav>
            </aside>

            <div class="settings-content">
                @if (_isLoading)
                {
                    <div class="loading-state">
                        <div class="loading-spinner"></div>
                        <p>Syncing preferences...</p>
                    </div>
                }
                else
                {
                    @if (_activeTab == "general")
                    {
                        <div class="tw-card settings-section animate-fade-up">
                            <h2>General Preferences</h2>
                            <div class="settings-group">
                                <div class="setting-row">
                                    <div class="setting-info">
                                        <span class="setting-label">Interface Theme</span>
                                        <span class="setting-desc">Adjust the visual appearance of the workspace.</span>
                                    </div>
                                    <select class="tw-input" @bind="_settings.Theme">
                                        <option value="dark">Deep Navy (Default)</option>
                                        <option value="light">Classic Light</option>
                                        <option value="system">System Preference</option>
                                    </select>
                                </div>

                                <div class="setting-row">
                                    <div class="setting-info">
                                        <span class="setting-label">Default Task Type</span>
                                        <span class="setting-desc">Preferred ML task for new training sessions.</span>
                                    </div>
                                    <select class="tw-input" @bind="_settings.DefaultTaskType">
                                        <option value="classification">Classification</option>
                                        <option value="regression">Regression</option>
                                    </select>
                                </div>
                            </div>
                            <button class="tw-btn-primary" @onclick="SaveChanges">Save Changes</button>
                        </div>
                    }
                    else if (_activeTab == "security")
                    {
                        <div class="tw-card settings-section animate-fade-up">
                            <h2>Security & Privacy</h2>
                            <div class="settings-group">
                                <div class="setting-row">
                                    <div class="setting-info">
                                        <span class="setting-label">Authentication Token</span>
                                        <span class="setting-desc">Your unique identifier for API requests.</span>
                                    </div>
                                    <code class="tw-mono">@(SessionState.SessionToken?.Length > 12 ? SessionState.SessionToken[..12] : "********")****</code>
                                </div>

                                <div class="setting-row">
                                    <div class="setting-info">
                                        <span class="setting-label">Password</span>
                                        <span class="setting-desc">Update your login credentials.</span>
                                    </div>
                                    <button class="tw-btn-ghost">Update Password</button>
                                </div>
                            </div>

                            <div class="danger-zone">
                                <h3 class="text-danger">Danger Zone</h3>
                                <p class="setting-desc">Irreversible account actions.</p>
                                <button class="tw-btn-ghost text-danger" @onclick="DeactivateWorkspace">Deactivate Workspace</button>
                            </div>
                        </div>
                    }
                    else if (_activeTab == "storage")
                    {
                        <div class="tw-card settings-section animate-fade-up">
                            <h2>Storage Management</h2>
                            <div class="settings-group">
                                <div class="setting-row">
                                    <div class="setting-info">
                                        <span class="setting-label">Auto-Archive Policy</span>
                                        <span class="setting-desc">Datasets older than this many days will be archived.</span>
                                    </div>
                                    <input type="number" class="tw-input" style="width: 100px;" @bind="_settings.AutoArchiveDays" min="1" max="365" />
                                </div>

                                <div class="setting-row">
                                    <div class="setting-info">
                                        <span class="setting-label">Storage Optimization</span>
                                        <span class="setting-desc">Compress older training history to save space.</span>
                                    </div>
                                    <label class="tw-switch">
                                        <input type="checkbox" @bind="_settings.StorageOptimization" />
                                        <span class="slider"></span>
                                    </label>
                                </div>
                            </div>
                            <button class="tw-btn-primary" @onclick="SaveChanges">Apply Policy</button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_message))
                    {
                        <div class="tw-badge @(_isError ? "danger" : "success") message-alert animate-fade-up">
                            @_message
                        </div>
                    }
                }
            </div>
        </div>
</div>

@code {
    private UserSettingsResponse _settings = new();
    private string _activeTab = "general";
    private bool _isLoading = true;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }

        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        _isLoading = true;
        try
        {
            var res = await UserApi.GetSettingsAsync();
            if (res != null) _settings = res;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveChanges()
    {
        _message = null;
        var req = new UpdateSettingsRequest
        {
            Theme = _settings.Theme,
            DefaultTaskType = _settings.DefaultTaskType,
            AutoArchiveDays = _settings.AutoArchiveDays,
            StorageOptimization = _settings.StorageOptimization
        };

        var success = await UserApi.UpdateSettingsAsync(req);
        if (success)
        {
            _message = "Settings updated successfully.";
            _isError = false;
        }
        else
        {
            _message = "Failed to update settings.";
            _isError = true;
        }
    }

    private async Task DeactivateWorkspace()
    {
        var success = await UserApi.DeactivateWorkspaceAsync();
        if (success)
        {
            _message = "Deactivation request received.";
            _isError = false;
        }
    }

    private void SetTab(string tab) {
        _activeTab = tab;
        _message = null;
    }
}

<style>
    .settings-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .settings-layout {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 32px;
        align-items: start;
    }

    .settings-sidebar {
        position: sticky;
        top: 100px;
    }

    .settings-nav {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .nav-item {
        background: none;
        border: 1px solid transparent;
        padding: 12px 20px;
        border-radius: 12px;
        color: var(--text-muted);
        text-align: left;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .nav-item:hover {
        background: rgba(255, 255, 255, 0.03);
        color: var(--text-h1);
    }

    .nav-item.active {
        background: rgba(129, 140, 248, 0.1);
        border-color: rgba(129, 140, 248, 0.2);
        color: var(--accent-violet);
    }

    .nav-icon { font-size: 1.1rem; }

    .settings-content {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .settings-section {
        padding: 40px;
    }

    .settings-section h2 {
        font-size: 1.5rem;
        margin-bottom: 24px;
        color: var(--text-h1);
    }

    .settings-group {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin-bottom: 32px;
    }

    .setting-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 0;
        border-bottom: 1px solid var(--border-subtle);
    }

    .setting-row:last-child { border-bottom: none; }

    .setting-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        max-width: 60%;
    }

    .setting-label {
        color: var(--text-h1);
        font-weight: 600;
        font-size: 1rem;
    }

    .setting-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    .danger-zone {
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1px solid var(--border-subtle);
    }

    .danger-zone h3 { font-size: 1.1rem; margin-bottom: 8px; }

    @@media (max-width: 900px) {
        .settings-layout { grid-template-columns: 1fr; }
        .settings-sidebar { position: static; }
        .settings-nav { flex-direction: row; overflow-x: auto; padding-bottom: 8px; }
        .nav-item { white-space: nowrap; }
    }
</style>
