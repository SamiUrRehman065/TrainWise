@page "/profile"
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject ILogger<Profile> Logger
@inject IJSRuntime JSRuntime
@using TrainWise.Web.Components.Common

<div class="profile-page animate-fade-up">
    <section class="tw-section-header">
        <h1 class="text-gradient">Your Profile</h1>
        <p class="subtitle">Manage your account identity and monitor workspace resource usage.</p>
    </section>

    <div class="profile-grid">
            <!-- IDENTITY CARD -->
            <div class="tw-card profile-main">
                <div class="profile-identity">
                    <div class="profile-avatar">
                        @SessionState.Username?.FirstOrDefault()
                    </div>
                    <div class="profile-title">
                        <h2>@SessionState.Username</h2>
                        @if (_stats?.IsPremium == true)
                        {
                            <span class="tw-badge success">Premium Member</span>
                        }
                        else
                        {
                            <span class="tw-badge warning">Standard Member</span>
                        }
                    </div>
                </div>

                <div class="profile-details">
                    <div class="detail-row">
                        <span class="detail-label">Username</span>
                        <span class="detail-value">@SessionState.Username</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Workspace ID</span>
                        <span class="detail-value tw-mono">TW-@(SessionState.Username?.GetHashCode().ToString("X") ?? "0000")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Joined</span>
                        <span class="detail-value">@(_stats?.MemberSince.ToString("MMMM yyyy") ?? "...")</span>
                    </div>
                </div>

                <div class="profile-actions">
                    <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/settings")'>⚙️ Edit Settings</button>
                    <button class="tw-btn-ghost text-danger" @onclick="LogoutAsync">🚪 Sign Out</button>
                </div>
            </div>

            <!-- STATS CARD -->
            <div class="tw-card profile-stats">
                <h3>📊 Workspace Statistics</h3>
                @if (_isLoading)
                {
                    <div class="loading-state">
                        <div class="loading-spinner"></div>
                        <p>Syncing statistics...</p>
                    </div>
                }
                else if (_stats is not null)
                {
                    <div class="stat-pills">
                        <div class="tw-stat-card">
                            <span class="stat-label">Datasets</span>
                            <span class="stat-number">@_stats.TotalDatasets</span>
                        </div>
                        <div class="tw-stat-card">
                            <span class="stat-label">Active</span>
                            <span class="stat-number">@_stats.ActiveDatasets</span>
                        </div>
                        <div class="tw-stat-card">
                            <span class="stat-label">Experiments</span>
                            <span class="stat-number">@_stats.TotalExperiments</span>
                        </div>
                        <div class="tw-stat-card">
                            <span class="stat-label">Total Storage</span>
                            <span class="stat-number">@FormatBytes(_stats.EstimatedSize)</span>
                        </div>
                    </div>

                    <div class="storage-usage">
                        <div class="usage-header">
                            <span>Storage Usage</span>
                            <span>@( (_stats.EstimatedSize / (1024.0 * 1024 * 1024)).ToString("0.##") ) / 5 GB</span>
                        </div>
                        <div class="tw-progress-bar">
                            <div class="progress-fill" style="width: @(Math.Min(100, (_stats.EstimatedSize / (5.0 * 1024 * 1024 * 1024)) * 100).ToString("F1"))%;"></div>
                        </div>
                    </div>
                }
            </div>
    </div>
</div>

@code {
    private DashboardStats? _stats;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
    }

    private async Task LoadStats()
    {
        try
        {
            _stats = await DatasetApi.GetStatsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading profile stats");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LogoutAsync()
    {
        SessionState.Clear();
        await SessionState.ClearStorageAsync(JSRuntime);
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    protected override void OnInitialized()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}

<style>
    .profile-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .profile-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 24px;
        align-items: start;
    }

    .profile-main {
        display: flex;
        flex-direction: column;
        gap: 32px;
        padding: 40px;
    }

    .profile-identity {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: var(--accent-grad);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
        box-shadow: 0 10px 30px rgba(129, 140, 248, 0.3);
    }

    .profile-title h2 {
        font-size: 1.75rem;
        margin-bottom: 8px;
        color: var(--text-h1);
    }

    .profile-details {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid var(--border-subtle);
    }

    .detail-label {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .detail-value {
        color: var(--text-h1);
        font-weight: 600;
    }

    .profile-actions {
        display: flex;
        gap: 16px;
        margin-top: 16px;
    }

    .profile-actions button { flex: 1; }

    .profile-stats {
        padding: 40px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .profile-stats h3 {
        color: var(--text-h1);
        font-size: 1.25rem;
        margin-bottom: 8px;
    }

    .stat-pills {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .storage-usage {
        margin-top: 24px;
        padding: 24px;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 20px;
        border: 1px solid var(--border-subtle);
    }

    .usage-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 600;
    }

    .loading-state {
        text-align: center;
        padding: 40px;
    }

    @@media (max-width: 900px) {
        .profile-grid { grid-template-columns: 1fr; }
    }
</style>
