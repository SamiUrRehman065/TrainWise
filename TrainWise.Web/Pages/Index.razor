@page "/"
@page "/Home"
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject TrainWise.Web.Services.Api.DatasetApi DatasetApi
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@using TrainWise.Web.Models

<PageTitle>Home — TrainWise</PageTitle>

<div class="home-container">
    <!-- SECTION 1: HERO -->
    <section class="hero-section">
        <div class="hero-content">
            <h1 class="animate-fade-up">Train ML Models <span class="text-gradient">Without Writing Code</span></h1>
            <p class="hero-subtext animate-fade-up" style="animation-delay: 0.1s;">
                TrainWise is your end-to-end machine learning workspace. 
                Upload a dataset, configure preprocessing, pick a model — 
                and get accuracy metrics, visualizations, and smart 
                recommendations in seconds.
            </p>
            <div class="hero-actions animate-fade-up" style="animation-delay: 0.2s;">
                <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/training")'>
                    <span>⚡ Start Training</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                </button>
                <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo("/datasets")'>
                    📁 Upload Dataset
                </button>
            </div>
        </div>
        <div class="hero-visual animate-float">
            <div class="brain-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9.5 14.5L14.5 9.5" stroke="url(#iconGrad)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M16.8926 12.1074C18.1074 13.3221 18.1074 15.2779 16.8926 16.4926C15.6779 17.7074 13.7221 17.7074 12.5074 16.4926L11.8926 15.8779C10.6779 14.6631 10.6779 12.7074 11.8926 11.4926C13.1074 10.2779 15.0631 10.2779 16.2779 11.4926L16.8926 12.1074Z" stroke="url(#iconGrad)" stroke-width="1.5"/>
                    <path d="M7.10742 11.8926C5.89264 10.6779 5.89264 8.72213 7.10742 7.50736C8.32219 6.29258 10.2779 6.29258 11.4926 7.50736L12.1074 8.12213C13.3221 9.3369 13.3221 11.2926 12.1074 12.5074C10.8926 13.7221 8.9369 13.7221 7.72213 12.5074L7.10742 11.8926Z" stroke="url(#iconGrad)" stroke-width="1.5"/>
                    <defs>
                        <linearGradient id="iconGrad" x1="6" y1="6" x2="18" y2="18" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#818cf8" />
                            <stop offset="1" stop-color="#22d3ee" />
                        </linearGradient>
                    </defs>
                </svg>
            </div>
            <div class="visual-glow"></div>
        </div>
    </section>

    <!-- SECTION 2: QUICK STATS (DYNAMIC) -->
    @if (SessionState.IsAuthenticated)
    {
        <section class="stats-section animate-fade-up">
            <div class="tw-section-header">
                <h2>Your Workspace at a Glance</h2>
            </div>
            <div class="stats-grid">
                <div class="tw-stat-card">
                    <span class="stat-number">@(_stats?.TotalDatasets ?? 0)</span>
                    <span class="stat-label">Total Datasets</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-number">@(_stats?.TotalExperiments ?? 0)</span>
                    <span class="stat-label">Experiments Run</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-number">@((_stats?.BestAccuracy ?? 0).ToString("P1"))</span>
                    <span class="stat-label">Best Accuracy</span>
                </div>
                <div class="tw-stat-card">
                    <span class="stat-number">@(_stats?.ModelsTried ?? 0)</span>
                    <span class="stat-label">Models Tried</span>
                </div>
            </div>
        </section>
    }

    <!-- SECTION 3: HOW IT WORKS -->
    <section class="how-it-works">
        <div class="tw-section-header">
            <h2>From Raw Data to Results in 3 Steps</h2>
            <p class="subtitle">Our automated pipeline handles the complexity so you can focus on insights.</p>
        </div>
        <div class="steps-grid">
            <div class="tw-card step-card" style="animation-delay: 0.1s;">
                <div class="step-badge">1</div>
                <div class="step-icon">📁</div>
                <h3>Upload Your Dataset</h3>
                <p>Support for CSV and XLSX files. TrainWise automatically detects column types and gives you an instant data summary including shape, nulls, and column statistics.</p>
            </div>
            <div class="tw-card step-card" style="animation-delay: 0.2s;">
                <div class="step-badge">2</div>
                <div class="step-icon">⚙️</div>
                <h3>Configure & Train</h3>
                <p>Choose from 12+ classification and regression models. Set preprocessing options — handle nulls, encode categoricals, scale features, or apply SMOTE.</p>
            </div>
            <div class="tw-card step-card" style="animation-delay: 0.3s;">
                <div class="step-badge">3</div>
                <div class="step-icon">📊</div>
                <h3>Visualize & Improve</h3>
                <p>Get interactive charts: Confusion Matrix, ROC Curve, and Feature Importance. Our advanced recommendation engine suggests specific technical improvements.</p>
            </div>
        </div>
    </section>

    <!-- SECTION 4: MODELS SHOWCASE -->
    <section class="models-section">
        <div class="tw-section-header">
            <h2>12+ Pro Models Ready to Train</h2>
            <p class="subtitle">State-of-the-art algorithms optimized for your data type.</p>
        </div>
        <div class="models-container">
            <div class="model-group">
                <label>Classification</label>
                <div class="badge-row">
                    <span class="tw-badge info">Random Forest</span>
                    <span class="tw-badge info">Logistic Regression</span>
                    <span class="tw-badge info">SVM</span>
                    <span class="tw-badge info">KNN</span>
                    <span class="tw-badge info">Decision Tree</span>
                    <span class="tw-badge info">Gradient Boosting</span>
                    <span class="tw-badge info">Naive Bayes</span>
                    <span class="tw-badge info">AdaBoost</span>
                </div>
            </div>
            <div class="model-group">
                <label>Regression</label>
                <div class="badge-row">
                    <span class="tw-badge info">Linear Regression</span>
                    <span class="tw-badge info">Ridge</span>
                    <span class="tw-badge info">Lasso</span>
                    <span class="tw-badge info">Random Forest Regressor</span>
                    <span class="tw-badge info">Decision Tree Regressor</span>
                    <span class="tw-badge info">Gradient Boosting Regressor</span>
                    <span class="tw-badge info">SVR</span>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 5: RECENT EXPERIMENTS -->
    <section class="recent-section">
        <div class="tw-section-header">
            <h2>Recent Activity</h2>
        </div>
        <div class="tw-card table-card">
            @if (SessionState.IsAuthenticated)
            {
                @if (_recentExperiments?.Any() == true)
                {
                    <table class="recent-table">
                        <thead>
                            <tr>
                                <th>Dataset</th>
                                <th>Model</th>
                                <th>Task</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exp in _recentExperiments.Take(5))
                            {
                                <tr>
                                    <td>@exp.DatasetName</td>
                                    <td><span class="tw-badge info">@exp.ModelName</span></td>
                                    <td class="tw-mono">@exp.TaskType</td>
                                    <td>@exp.CreatedAt.ToShortDateString()</td>
                                    <td>
                                        <button class="tw-btn-ghost sm" @onclick='() => NavManager.NavigateTo($"/experiments/{exp.ExperimentId}")'>View Details</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="table-footer">
                        <a href="/experiments" class="view-all-link">View full history →</a>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon">📊</div>
                        <p>No experiments yet. Upload a dataset to get started.</p>
                        <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/datasets")'>Start Training</button>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">🔒</div>
                    <p>Please login to see your workspace statistics.</p>
                    <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/login")'>Login Now</button>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private DashboardStats? _stats;
    private List<TrainingHistoryItem>? _recentExperiments;

    protected override async Task OnInitializedAsync()
    {
        if (SessionState.IsAuthenticated)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        try
        {
            _stats = await DatasetApi.GetStatsAsync();
            var history = await ExperimentApi.GetTrainingHistoryAsync();
            _recentExperiments = history?.TrainingHistory;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
    }
}

<style>
    .home-container {
        display: flex;
        flex-direction: column;
        gap: 80px;
        padding-bottom: 80px;
    }

    .hero-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 60px;
        padding: 40px 0;
        position: relative;
    }

    .hero-content h1 {
        font-size: 3.5rem;
        margin-bottom: 24px;
    }

    .hero-subtext {
        font-size: 1.15rem;
        max-width: 540px;
        margin-bottom: 40px;
    }

    .hero-actions {
        display: flex;
        gap: 16px;
    }

    .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .brain-icon {
        width: 300px;
        height: 300px;
        z-index: 1;
    }

    .visual-glow {
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(129, 140, 248, 0.15) 0%, transparent 70%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .step-card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .step-badge {
        position: absolute;
        top: -12px;
        right: 24px;
        background: var(--bg-elevated);
        border: 1px solid var(--border-active);
        color: var(--accent-violet);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.9rem;
    }

    .step-icon {
        font-size: 2.5rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .models-container {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .model-group {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .models-note {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-style: italic;
    }

    .table-card {
        padding: 0;
        overflow: hidden;
    }

    .recent-table {
        width: 100%;
        border-collapse: collapse;
    }

    .recent-table th {
        text-align: left;
        padding: 16px 24px;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid var(--border-subtle);
    }

    .recent-table td {
        padding: 16px 24px;
        font-size: 0.9rem;
        border-bottom: 1px solid var(--border-subtle);
    }

    .hp-mono {
        font-family: var(--font-mono);
        color: var(--accent-cyan);
    }

    .table-footer {
        padding: 16px 24px;
        text-align: right;
    }

    .view-all-link {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--accent-violet);
    }

    .empty-state {
        padding: 60px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
    }

    .empty-icon {
        font-size: 3rem;
        opacity: 0.5;
    }

    @@media (max-width: 1024px) {
        .hero-section {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .hero-actions {
            justify-content: center;
        }
        .hero-visual {
            order: -1;
        }
        .steps-grid {
            grid-template-columns: 1fr;
        }
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
