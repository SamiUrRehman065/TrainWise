@page "/login"
@inject TrainWise.Web.Services.Api.AuthApi AuthApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager

<div class="auth-page-wrapper">
    <div class="gradient-blob"></div>
    <div class="particles"></div>

    <div class="auth-card animate-fade-up">
        @if (SessionState.IsAuthenticated)
        {
            <div class="auth-success-state">
                <div class="success-icon-wrapper">
                    <span class="success-icon">👋</span>
                </div>
                <h1 class="auth-title text-gradient">Welcome back, @SessionState.Username!</h1>
                <p class="auth-subtitle">You are already signed in to your workspace.</p>
                <div class="success-actions">
                    <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/")'>Go to Home</button>
                    <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo("/dashboard")'>View Dashboard</button>
                </div>
            </div>
        }
        else
        {
            <div class="auth-header">
                <div class="auth-logo">
                    <span class="logo-symbol">TW</span>
                </div>
                <h1 class="auth-title text-gradient">TrainWise</h1>
                <p class="auth-tagline">"Empowering Intelligence, One Model at a Time."</p>
            </div>

            <div class="auth-form">
                <div class="tw-input-group">
                    <label class="tw-label">Username</label>
                    <div class="tw-input-wrapper">
                        <span class="input-icon">👤</span>
                        <input
                            type="text"
                            class="tw-input"
                            @bind="_username"
                            placeholder="Enter your username"
                            @onkeyup='async (e) => { if (e.Key == "Enter") await LoginAsync(); }'
                            autocomplete="username" />
                    </div>
                </div>

                <div class="tw-input-group">
                    <label class="tw-label">Password</label>
                    <div class="tw-input-wrapper">
                        <span class="input-icon">🔒</span>
                        <input
                            type="password"
                            class="tw-input"
                            @bind="_password"
                            placeholder="••••••••"
                            @onkeyup='async (e) => { if (e.Key == "Enter") await LoginAsync(); }'
                            autocomplete="current-password" />
                    </div>
                </div>

                <button class="tw-btn-primary btn-lg auth-submit @(_isLoading ? "btn-loading" : "")" @onclick="LoginAsync" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-inline"></span>
                        <span>Verifying...</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                        <span class="btn-arrow">→</span>
                    }
                </button>

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="tw-badge @(_isSuccess ? "success" : "danger") full-width">
                        @_message
                    </div>
                }
            </div>

            <div class="auth-demo-card">
                <div class="demo-badge">DEMO ACCESS</div>
                <div class="demo-row">
                    <span>User: <code>demo</code></span>
                    <span>Pass: <code>demo</code></span>
                </div>
            </div>

            <div class="auth-footer">
                <p>New to TrainWise? <a href="/signup" class="link-gradient">Create Account</a></p>
            </div>
        }
    </div>
</div>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string? _message;
    private bool _isLoading = false;
    private bool _isSuccess = false;

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _message = "Credentials required";
            _isSuccess = false;
            return;
        }

        _isLoading = true;
        _message = null;

        var success = await AuthApi.LoginAsync(_username, _password);

        if (success)
        {
            _isSuccess = true;
            _message = "Success! Initializing workspace...";
            await Task.Delay(800);
            NavManager.NavigateTo("/", forceLoad: true); // Redirect to Home as requested
        }
        else
        {
            _isSuccess = false;
            _message = "Invalid username or password";
            _password = string.Empty;
        }

        _isLoading = false;
    }
}

<style>
    .auth-page-wrapper {
        position: fixed;
        inset: 0;
        background: radial-gradient(circle at 50% 50%, #161b27 0%, #0d1117 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 5000;
        overflow: hidden;
    }

    .gradient-blob {
        position: absolute;
        width: 1000px;
        height: 1000px;
        background: radial-gradient(circle, rgba(129, 140, 248, 0.15) 0%, transparent 70%);
        top: -500px;
        right: -500px;
        animation: float 20s infinite alternate;
    }

    .particles {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        opacity: 0.5;
    }

    .auth-card {
        width: 100%;
        max-width: 460px;
        padding: 48px;
        background: rgba(22, 27, 39, 0.7);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 32px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
        position: relative;
        z-index: 10;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .auth-logo {
        width: 64px;
        height: 64px;
        background: var(--accent-grad);
        border-radius: 20px;
        margin: 0 auto 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 30px rgba(129, 140, 248, 0.3);
    }

    .logo-symbol {
        font-weight: 900;
        color: white;
        font-size: 1.5rem;
    }

    .auth-title {
        font-size: 2.25rem;
        margin-bottom: 8px;
        letter-spacing: -1px;
    }

    .auth-tagline {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin: 0;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .tw-input-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .tw-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        padding-left: 4px;
    }

    .tw-input-wrapper {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1rem;
        opacity: 0.6;
    }

    .tw-input {
        width: 100%;
        padding-left: 48px !important;
    }

    .auth-submit {
        margin-top: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
    }

    .btn-lg { height: 56px; font-size: 1rem; }

    .btn-arrow {
        transition: transform 0.3s ease;
    }

    .auth-submit:hover .btn-arrow {
        transform: translateX(5px);
    }

    .auth-demo-card {
        margin-top: 32px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        position: relative;
    }

    .demo-badge {
        position: absolute;
        top: -10px;
        left: 20px;
        background: #1e293b;
        padding: 2px 10px;
        font-size: 0.65rem;
        font-weight: 800;
        border-radius: 50px;
        color: var(--accent-cyan);
        border: 1px solid var(--accent-cyan);
    }

    .demo-row {
        display: flex;
        justify-content: space-around;
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .demo-row code { color: var(--accent-cyan); font-weight: 700; }

    .auth-footer {
        margin-top: 32px;
        text-align: center;
        font-size: 0.95rem;
    }

    .link-gradient {
        background: var(--accent-grad);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 700;
    }

    .full-width { width: 100%; justify-content: center; margin-top: 16px; }

    .auth-success-state {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
    }

    .success-icon-wrapper {
        width: 80px;
        height: 80px;
        background: rgba(52, 211, 153, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
    }

    .success-actions {
        display: flex;
        gap: 16px;
        width: 100%;
        margin-top: 16px;
    }

    .success-actions button { flex: 1; }

    .spinner-inline {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
</style>
