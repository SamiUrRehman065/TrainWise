@page "/signup"
@inject TrainWise.Web.Services.Api.AuthApi AuthApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager

@if (SessionState.IsAuthenticated)
{
    <div class="auth-page">
        <div class="auth-card">
            <h1 class="auth-title">Redirecting...</h1>
            <p class="auth-subtitle">You are already signed in.</p>
        </div>
    </div>
}
else
{
    <div class="auth-page">
        <div class="auth-card">
            <h1 class="auth-title">Create account</h1>
            <p class="auth-subtitle">Join TrainWise to start your ML journey</p>

            <div class="auth-form">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input
                        id="username"
                        type="text"
                        @bind="_username"
                        placeholder="Choose a username"
                        @onkeyup='async (e) => { if (e.Key == "Enter") await SignupAsync(); }' />
                    @if (!string.IsNullOrEmpty(_usernameError))
                    {
                        <small class="field-error">@_usernameError</small>
                    }
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input
                        id="password"
                        type="password"
                        @bind="_password"
                        placeholder="Min 6 characters"
                        @onkeyup='async (e) => { if (e.Key == "Enter") await SignupAsync(); }' />
                    @if (!string.IsNullOrEmpty(_passwordError))
                    {
                        <small class="field-error">@_passwordError</small>
                    }
                </div>

                <div class="form-group">
                    <label for="confirm-password">Confirm password</label>
                    <input
                        id="confirm-password"
                        type="password"
                        @bind="_confirmPassword"
                        placeholder="Confirm password"
                        @onkeyup='async (e) => { if (e.Key == "Enter") await SignupAsync(); }' />
                    @if (!string.IsNullOrEmpty(_confirmError))
                    {
                        <small class="field-error">@_confirmError</small>
                    }
                </div>

                <button class="button primary auth-submit" @onclick="SignupAsync" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span>Creating account...</span>
                    }
                    else
                    {
                        <span>Sign up</span>
                    }
                </button>

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="alert alert-@(_isSuccess ? "success" : "error")">
                        @_message
                    </div>
                }
            </div>

            <div class="auth-footer">
                <p>Already have an account? <a href="/login">Sign in</a></p>
            </div>
        </div>
    </div>
}

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _message;
    private string? _usernameError;
    private string? _passwordError;
    private string? _confirmError;
    private bool _isLoading = false;
    private bool _isSuccess = false;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/stats", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private void ValidateForm()
    {
        _usernameError = null;
        _passwordError = null;
        _confirmError = null;

        if (string.IsNullOrWhiteSpace(_username))
        {
            _usernameError = "Username is required";
        }
        else if (_username.Length < 3)
        {
            _usernameError = "Username must be at least 3 characters";
        }

        if (string.IsNullOrWhiteSpace(_password))
        {
            _passwordError = "Password is required";
        }
        else if (_password.Length < 6)
        {
            _passwordError = "Password must be at least 6 characters";
        }

        if (_password != _confirmPassword)
        {
            _confirmError = "Passwords do not match";
        }
    }

    private async Task SignupAsync()
    {
        ValidateForm();

        if (!string.IsNullOrEmpty(_usernameError) ||
            !string.IsNullOrEmpty(_passwordError) ||
            !string.IsNullOrEmpty(_confirmError))
        {
            return;
        }

        _isLoading = true;
        _message = null;

        var success = await AuthApi.SignupAsync(_username, _password);

        if (success)
        {
            _isSuccess = true;
            _message = "Account created! Redirecting to dashboard...";
            await Task.Delay(1000);
            NavManager.NavigateTo("/stats");
        }
        else
        {
            _isSuccess = false;
            _message = "Signup failed. Username may already be taken.";
        }

        _isLoading = false;
    }
}

<style>
    .auth-page {
        display: flex;
        justify-content: center;
        padding-top: var(--space-8);
    }

    .auth-card {
        width: 100%;
        max-width: 380px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: var(--space-6) var(--space-5);
    }

    .auth-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: var(--space-1);
        text-align: center;
    }

    .auth-subtitle {
        font-size: 14px;
        color: var(--color-text-secondary);
        text-align: center;
        margin-bottom: var(--space-5);
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .auth-submit {
        width: 100%;
        margin-top: var(--space-2);
    }

    .field-error {
        color: var(--color-negative);
        font-size: 12px;
        margin-top: var(--space-1);
    }

    .auth-footer {
        margin-top: var(--space-5);
        padding-top: var(--space-4);
        border-top: 1px solid var(--color-border);
        text-align: center;
        font-size: 13px;
    }
</style>
