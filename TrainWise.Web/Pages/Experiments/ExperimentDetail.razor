@page "/experiments/{id}"
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject ILogger<ExperimentDetail> Logger
@inject IJSRuntime JSRuntime
@using TrainWise.Web.Components.Common
@using ExperimentModel = TrainWise.Web.Models.ExperimentDetail


@if (!SessionState.IsAuthenticated)
{
    <div class="alert alert-warning">
        <p>Please <a href="/login">sign in</a> to view experiments.</p>
    </div>
}
else if (_isLoading)
{
    <div class="state-card">
        <div class="loading-spinner"></div>
        <p class="state-text">Loading experiment details…</p>
    </div>
}
else if (_experiment is null)
{
    <div class="state-card empty">
        <h3>Experiment not found</h3>
        <p class="state-text">The experiment you're looking for doesn't exist.</p>
        <a href="/experiments" class="button primary">Back to history</a>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1>@_experiment.ModelName</h1>
            <p class="page-desc">@_experiment.TaskType experiment on @_experiment.DatasetName</p>
        </div>
        <div class="page-actions">
            <button class="button ghost" @onclick="ExportAsync">Export</button>
        </div>
    </div>

    <div class="detail-layout">
        <div class="detail-row">
            <div class="detail-card">
                <h3>Configuration</h3>
                <div class="config-grid">
                    <div class="config-item">
                        <span class="config-label">Model</span>
                        <span class="config-value">@_experiment.ModelName</span>
                    </div>
                    <div class="config-item">
                        <span class="config-label">Task type</span>
                        <span class="config-value"><span class="tag">@_experiment.TaskType</span></span>
                    </div>
                    <div class="config-item">
                        <span class="config-label">Dataset</span>
                        <span class="config-value">@_experiment.DatasetName</span>
                    </div>
                    <div class="config-item">
                        <span class="config-label">Created</span>
                        <span class="config-value">@_experiment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            <div class="detail-card">
                <h3>Performance</h3>
                <div class="metrics-grid">
                    @if (_experiment.Metrics is not null)
                    {
                        <div class="metric-item">
                            <span class="metric-label">Accuracy</span>
                            <span class="metric-value">@(_experiment.Metrics.Accuracy.ToString("0.00%"))</span>
                        </div>
                        <div class="metric-item">
                            <span class="metric-label">Precision</span>
                            <span class="metric-value">@(_experiment.Metrics.Precision.ToString("0.00%"))</span>
                        </div>
                        <div class="metric-item">
                            <span class="metric-label">Recall</span>
                            <span class="metric-value">@(_experiment.Metrics.Recall.ToString("0.00%"))</span>
                        </div>
                        <div class="metric-item">
                            <span class="metric-label">F1 score</span>
                            <span class="metric-value">@(_experiment.Metrics.F1Score.ToString("0.00%"))</span>
                        </div>
                        <div class="metric-item">
                            <span class="metric-label">Duration</span>
                            <span class="metric-value">@(_experiment.TrainingDurationSec?.ToString("0.0") ?? "N/A")s</span>
                        </div>
                        <div class="metric-item">
                            <span class="metric-label">Status</span>
                            <span class="metric-value"><span class="badge success">Completed</span></span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="detail-card">
            <h3>Hyperparameters</h3>
            <div class="params-list">
                @if (_experiment.HyperParameters?.Any() == true)
                {
                    @foreach (var param in _experiment.HyperParameters)
                    {
                        <div class="param-row">
                            <span class="param-name">@param.Key</span>
                            <span class="param-value mono">@FormatHyperparamValue(param.Value)</span>
                        </div>
                    }
                }
                else
                {
                    <div class="param-row">
                        <span class="param-name">No hyperparameters configured</span>
                    </div>
                }
            </div>
        </div>

        <div class="detail-actions">
            <a href="/experiments" class="button ghost">Back to history</a>
            <a href="/experiments/compare" class="button ghost">Compare</a>
            <button class="button primary" @onclick="ExportAsync">Download results</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private ExperimentModel? _experiment;
    private bool _isLoading = true;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Id))
        {
            _isLoading = false;
            return;
        }

        await LoadExperimentDetails();
    }

    private async Task LoadExperimentDetails()
    {
        try
        {
            if (!Guid.TryParse(Id, out var experimentId))
            {
                return;
            }

            _experiment = await ExperimentApi.GetAsync(experimentId);

            _breadcrumbs = new()
            {
                new BreadcrumbItem { Label = "History", Url = "/experiments" },
                new BreadcrumbItem { Label = _experiment?.ModelName ?? "Experiment" }
            };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading experiment details");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatHyperparamValue(object? value)
    {
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.Null => "Not set",
                System.Text.Json.JsonValueKind.True => "true",
                System.Text.Json.JsonValueKind.False => "false",
                _ => je.ToString()
            };
        }
        return value?.ToString() ?? "Not set";
    }

    private async Task ExportAsync()
    {
        try
        {
            if (_experiment is null) return;

            var json = System.Text.Json.JsonSerializer.Serialize(_experiment, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            await JSRuntime.InvokeVoidAsync("downloadFile", bytes, $"experiment_{Id}_results.json");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting experiment");
        }
    }
}

<style>
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-5);
        margin-bottom: var(--space-6);
        flex-wrap: wrap;
    }

    .page-header h1 {
        font-family: var(--font-ui);
        font-size: 1.75rem;
        font-weight: 500;
        margin: 0 0 var(--space-1);
        color: var(--color-text);
    }

    .page-desc {
        margin: 0;
        color: var(--color-text-secondary);
        font-size: 0.9375rem;
    }

    .page-actions {
        flex-shrink: 0;
    }

    .detail-layout {
        display: grid;
        gap: var(--space-5);
    }

    .detail-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-5);
    }

    .detail-card {
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        padding: var(--space-5);
    }

    .detail-card h3 {
        font-family: var(--font-ui);
        font-size: 1rem;
        font-weight: 500;
        margin: 0 0 var(--space-4);
        color: var(--color-text);
    }

    .config-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
    }

    .config-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        padding: var(--space-3);
        border: 1px solid var(--color-border);
        background: var(--color-bg);
    }

    .config-label {
        font-size: 0.75rem;
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 500;
    }

    .config-value {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text);
    }

    .metrics-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
    }

    .metric-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        padding: var(--space-4);
        border: 1px solid var(--color-border);
        background: var(--color-bg);
    }

    .metric-label {
        font-size: 0.75rem;
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 500;
    }

    .metric-value {
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--color-accent);
        font-family: var(--font-mono);
    }

    .params-list {
        display: grid;
        gap: var(--space-1);
    }

    .param-row {
        display: flex;
        justify-content: space-between;
        padding: var(--space-2) var(--space-3);
        border: 1px solid var(--color-border);
        background: var(--color-bg);
    }

    .param-name {
        font-weight: 500;
        font-size: 0.875rem;
        color: var(--color-text);
    }

    .param-value {
        font-size: 0.875rem;
        color: var(--color-text-secondary);
    }

    .param-value.mono {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
    }

    .detail-actions {
        display: flex;
        gap: var(--space-3);
        justify-content: flex-end;
    }

    .alert {
        padding: var(--space-3) var(--space-4);
        font-size: 0.875rem;
        border: 1px solid var(--color-border);
    }

    .alert p {
        margin: 0;
    }

    .alert a {
        color: var(--color-accent);
        text-decoration: underline;
    }

    .alert-warning {
        background: var(--color-bg);
        color: var(--color-text);
    }

    .state-card {
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        padding: var(--space-7) var(--space-5);
        text-align: center;
    }

    .state-card.empty h3 {
        font-family: var(--font-ui);
        font-size: 1.125rem;
        font-weight: 500;
        margin: 0 0 var(--space-2);
        color: var(--color-text);
    }

    .state-text {
        margin: 0;
        color: var(--color-text-secondary);
        font-size: 0.875rem;
    }

    .state-card .button {
        margin-top: var(--space-4);
    }

    @@media (max-width: 720px) {
        .detail-row {
            grid-template-columns: 1fr;
        }

        .config-grid,
        .metrics-grid {
            grid-template-columns: 1fr;
        }

        .detail-actions {
            flex-direction: column;
        }
    }
</style>
