@page "/experiments/{id}"
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject ILogger<ExperimentDetail> Logger
@inject IJSRuntime JSRuntime
@using TrainWise.Web.Components.Common
@using ExperimentModel = TrainWise.Web.Models.ExperimentDetail

<div class="experiment-detail-page">
    @if (!SessionState.IsAuthenticated)
    {
        <div class="tw-card animate-fade-up">
            <p>Please <a href="/login">sign in</a> to view experiment results.</p>
        </div>
    }
    else if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 60px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Generating Model Report...</p>
        </div>
    }
    else if (_experiment is null)
    {
        <div class="tw-card empty-state animate-fade-up">
            <div class="empty-icon">⚠️</div>
            <h3>Experiment Not Found</h3>
            <p class="subtitle">The requested training run could not be located in your history.</p>
            <button class="tw-btn-primary" style="margin-top: 24px;" @onclick='() => NavManager.NavigateTo("/experiments")'>Back to History</button>
        </div>
    }
    else
    {
        <section class="tw-section-header animate-fade-up">
            <h1 class="text-gradient">@_experiment.ModelName</h1>
            <p class="subtitle">Analysis of the @_experiment.TaskType model trained on <strong>@_experiment.DatasetName</strong>.</p>
            <div class="header-actions">
                <button class="tw-btn-ghost" @onclick="ExportAsync">📤 Export JSON</button>
                <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/experiments/compare")'>⚖️ Compare Run</button>
            </div>
        </section>

        <!-- PERFORMANCE DASHBOARD -->
        <div class="performance-grid animate-fade-up">
            <div class="tw-stat-card">
                <span class="stat-label">Accuracy Score</span>
                <span class="stat-number">@(_experiment.Metrics?.Accuracy.ToString("P1") ?? "N/A")</span>
            </div>
            <div class="tw-stat-card">
                <span class="stat-label">Precision</span>
                <span class="stat-number">@(_experiment.Metrics?.Precision.ToString("P1") ?? "N/A")</span>
            </div>
            <div class="tw-stat-card">
                <span class="stat-label">Recall</span>
                <span class="stat-number">@(_experiment.Metrics?.Recall.ToString("P1") ?? "N/A")</span>
            </div>
            <div class="tw-stat-card">
                <span class="stat-label">F1-Score</span>
                <span class="stat-number">@(_experiment.Metrics?.F1Score.ToString("P1") ?? "N/A")</span>
            </div>
        </div>

        <div class="report-grid">
            <div class="report-main animate-fade-up">
                <div class="tw-card">
                    <h3>⚙️ Model Configuration</h3>
                    <div class="config-details">
                        <div class="detail-item">
                            <label>Training Duration</label>
                            <span class="tw-mono">@(_experiment.TrainingDurationSec?.ToString("F2") ?? "0.00") seconds</span>
                        </div>
                        <div class="detail-item">
                            <label>Completion Date</label>
                            <span>@_experiment.CreatedAt.ToString("MMMM dd, yyyy • HH:mm")</span>
                        </div>
                        <div class="detail-item">
                            <label>Execution Status</label>
                            <span class="tw-badge success">Completed</span>
                        </div>
                        <div class="detail-item">
                            <label>Task Category</label>
                            <span class="tw-badge info">@_experiment.TaskType</span>
                        </div>
                    </div>
                </div>

                <div class="tw-card">
                    <h3>🧪 Hyperparameters</h3>
                    <div class="params-container">
                        @if (_experiment.HyperParameters?.Any() == true)
                        {
                            <table class="params-table">
                                <thead>
                                    <tr>
                                        <th>Parameter</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var param in _experiment.HyperParameters)
                                    {
                                        <tr>
                                            <td class="param-name">@param.Key</td>
                                            <td class="param-value tw-mono">@FormatHyperparamValue(param.Value)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Standard default configuration used for this run.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="report-sidebar animate-fade-up" style="animation-delay: 0.1s;">
                <div class="tw-card action-card">
                    <h3>Next Steps</h3>
                    <div class="action-list">
                        <button class="tw-btn-primary btn-full" @onclick='() => NavManager.NavigateTo($"/results/{Id}/recommendations")'>
                            💡 Get AI Insights
                        </button>
                        <button class="tw-btn-ghost btn-full" @onclick="ExportAsync">
                            📥 Download Report
                        </button>
                        <button class="tw-btn-ghost btn-full" @onclick='() => NavManager.NavigateTo("/experiments")'>
                            🔙 Back to History
                        </button>
                    </div>
                </div>

                <div class="tw-card tip-card">
                    <span class="tip-icon">💡</span>
                    <p class="tip-text">This model shows high precision but lower recall. Consider adjusting the <strong>decision threshold</strong> or applying <strong>SMOTE</strong> if you have imbalanced classes.</p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }
    private ExperimentModel? _experiment;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Id))
        {
            _isLoading = false;
            return;
        }
        await LoadExperimentDetails();
    }

    private async Task LoadExperimentDetails()
    {
        try
        {
            if (Guid.TryParse(Id, out var experimentId))
            {
                _experiment = await ExperimentApi.GetAsync(experimentId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading experiment details");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatHyperparamValue(object? value)
    {
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.Null => "None",
                System.Text.Json.JsonValueKind.True => "True",
                System.Text.Json.JsonValueKind.False => "False",
                _ => je.ToString()
            };
        }
        return value?.ToString() ?? "Default";
    }

    private async Task ExportAsync()
    {
        if (_experiment is null) return;
        var json = System.Text.Json.JsonSerializer.Serialize(_experiment, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        await JSRuntime.InvokeVoidAsync("downloadFile", bytes, $"trainwise_report_{_experiment.ModelName?.ToLower() ?? "model"}_{(Id?.Length >= 8 ? Id[..8] : "run")}.json");
    }
}

<style>
    .experiment-detail-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .performance-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .report-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 32px;
        align-items: start;
    }

    .report-main {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .report-main h3, .report-sidebar h3 {
        font-size: 1.1rem;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .config-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .detail-item label {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .detail-item span {
        font-size: 1rem;
        font-weight: 500;
        color: var(--text-h1);
    }

    .params-container {
        background: var(--bg-surface);
        border-radius: 12px;
        border: 1px solid var(--border-subtle);
        overflow: hidden;
    }

    .params-table {
        width: 100%;
        border-collapse: collapse;
    }

    .params-table th {
        text-align: left;
        padding: 12px 20px;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.02);
    }

    .params-table td {
        padding: 12px 20px;
        font-size: 0.9rem;
        color: var(--text-body);
        border-top: 1px solid var(--border-subtle);
    }

    .param-name { font-weight: 600; color: var(--text-h1); }

    .action-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .btn-full { width: 100%; justify-content: center; }

    .tip-card {
        background: var(--accent-grad);
        padding: 1px;
        border: none;
    }

    .tip-card::after {
        content: '';
        position: absolute;
        inset: 1px;
        background: var(--bg-surface);
        border-radius: 15px;
        z-index: 0;
    }

    .tip-icon { font-size: 1.5rem; position: relative; z-index: 1; }
    .tip-text { font-size: 0.85rem; color: var(--text-body); line-height: 1.6; margin: 0; position: relative; z-index: 1; }

    @@media (max-width: 1200px) {
        .performance-grid { grid-template-columns: repeat(2, 1fr); }
        .report-grid { grid-template-columns: 1fr; }
        .config-details { grid-template-columns: 1fr; }
    }
</style>
