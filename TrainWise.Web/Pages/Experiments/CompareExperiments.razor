@page "/experiments/compare"
@page "/compare"
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject ILogger<CompareExperiments> Logger
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
@using TrainWise.Web.Components.Common

<div class="compare-page">
    <section class="tw-section-header animate-fade-up">
            <h1 class="text-gradient">Compare Experiments</h1>
            <p class="subtitle">Select two training runs to perform a side-by-side performance analysis and feature audit.</p>
        </section>

        <div class="compare-controls animate-fade-up">
            <div class="tw-card selector-card">
                <div class="selectors-grid">
                    <div class="selector-item">
                        <label>Baseline Run (Experiment 1)</label>
                        <select class="tw-input" @bind="_exp1Id" @bind:after="OnExperimentSelected">
                            <option value="">-- Select baseline --</option>
                            @if (_experiments?.Any() == true)
                            {
                                @foreach (var exp in _experiments)
                                {
                                    <option value="@exp.ExperimentId">@exp.ModelName (@exp.TaskType)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="selector-item">
                        <label>Comparison Run (Experiment 2)</label>
                        <select class="tw-input" @bind="_exp2Id" @bind:after="OnExperimentSelected" disabled="@(string.IsNullOrEmpty(_exp1Id))">
                            <option value="">-- Select comparison --</option>
                            @if (_experiments?.Any() == true)
                            {
                                var baseline = _experiments.FirstOrDefault(e => e.ExperimentId.ToString() == _exp1Id);
                                @foreach (var exp in _experiments.Where(e => e.ExperimentId.ToString() != _exp1Id && (baseline == null || e.DatasetId == baseline.DatasetId)))
                                {
                                    <option value="@exp.ExperimentId">@exp.ModelName (@exp.TaskType) - @exp.CreatedAt.ToShortDateString()</option>
                                }
                            }
                        </select>
                        @if (string.IsNullOrEmpty(_exp1Id))
                        {
                            <span class="tw-info-text">Select a baseline first</span>
                        }
                    </div>
                    <button class="tw-btn-primary" @onclick="CompareAsync" disabled="@(string.IsNullOrEmpty(_exp1Id) || string.IsNullOrEmpty(_exp2Id) || _isComparing)">
                        @if (_isComparing)
                        {
                            <span class="spinner-inline"></span>
                        }
                        else
                        {
                            <span>📊 Compare Runs</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        @if (_isComparing)
        {
            <div class="tw-card animate-fade-up" style="text-align: center; padding: 60px;">
                <div class="loading-spinner"></div>
                <p class="stat-label" style="margin-top: 16px;">Analyzing Deltas...</p>
            </div>
        }
        else if (_fullExp1 is not null && _fullExp2 is not null)
        {
            <div class="comparison-results animate-fade-up">
                <div class="tw-card table-card">
                    <div class="table-scroll">
                        <table class="tw-table compare-table">
                            <thead>
                                <tr>
                                    <th>Metric Category</th>
                                    <th>
                                        <div class="model-head">
                                            <span class="tw-badge info">Model A</span>
                                            <h4>@_fullExp1.ModelName</h4>
                                        </div>
                                    </th>
                                    <th>
                                        <div class="model-head">
                                            <span class="tw-badge warning">Model B</span>
                                            <h4>@_fullExp2.ModelName</h4>
                                        </div>
                                    </th>
                                    <th>Variance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- BASIC METRICS -->
                                <tr class="table-section"><td colspan="4">Core Performance</td></tr>
                                <tr>
                                    <td>Accuracy / Score</td>
                                    <td class="tw-mono">@(_fullExp1.Metrics?.Accuracy.ToString("P2") ?? "N/A")</td>
                                    <td class="tw-mono">@(_fullExp2.Metrics?.Accuracy.ToString("P2") ?? "N/A")</td>
                                    <td>
                                        @RenderVariance(_fullExp1.Metrics?.Accuracy, _fullExp2.Metrics?.Accuracy, true)
                                    </td>
                                </tr>
                                <tr>
                                    <td>F1-Score</td>
                                    <td class="tw-mono">@(_fullExp1.Metrics?.F1Score.ToString("P2") ?? "N/A")</td>
                                    <td class="tw-mono">@(_fullExp2.Metrics?.F1Score.ToString("P2") ?? "N/A")</td>
                                    <td>
                                        @RenderVariance(_fullExp1.Metrics?.F1Score, _fullExp2.Metrics?.F1Score, true)
                                    </td>
                                </tr>
                                <tr>
                                    <td>Precision</td>
                                    <td class="tw-mono">@(_fullExp1.Metrics?.Precision.ToString("P2") ?? "N/A")</td>
                                    <td class="tw-mono">@(_fullExp2.Metrics?.Precision.ToString("P2") ?? "N/A")</td>
                                    <td>
                                        @RenderVariance(_fullExp1.Metrics?.Precision, _fullExp2.Metrics?.Precision, true)
                                    </td>
                                </tr>
                                <tr>
                                    <td>Recall</td>
                                    <td class="tw-mono">@(_fullExp1.Metrics?.Recall.ToString("P2") ?? "N/A")</td>
                                    <td class="tw-mono">@(_fullExp2.Metrics?.Recall.ToString("P2") ?? "N/A")</td>
                                    <td>
                                        @RenderVariance(_fullExp1.Metrics?.Recall, _fullExp2.Metrics?.Recall, true)
                                    </td>
                                </tr>

                                <!-- SYSTEM METRICS -->
                                <tr class="table-section"><td colspan="4">System & Metadata</td></tr>
                                <tr>
                                    <td>Training Duration</td>
                                    <td>@(_fullExp1.TrainingDurationSec?.ToString("F2") ?? "0.00")s</td>
                                    <td>@(_fullExp2.TrainingDurationSec?.ToString("F2") ?? "0.00")s</td>
                                    <td>
                                        @RenderVariance(_fullExp1.TrainingDurationSec, _fullExp2.TrainingDurationSec, false)
                                    </td>
                                </tr>
                                <tr>
                                    <td>Dataset Used</td>
                                    <td>@_fullExp1.DatasetName</td>
                                    <td>@_fullExp2.DatasetName</td>
                                    <td>-</td>
                                </tr>

                                <!-- HYPERPARAMETERS -->
                                <tr class="table-section"><td colspan="4">Hyperparameter Audit</td></tr>
                                @foreach (var key in GetAllKeys(_fullExp1.HyperParameters, _fullExp2.HyperParameters))
                                {
                                    var val1 = FormatHyperparamValue(_fullExp1.HyperParameters?.GetValueOrDefault(key));
                                    var val2 = FormatHyperparamValue(_fullExp2.HyperParameters?.GetValueOrDefault(key));
                                    <tr class="@(val1 != val2 ? "row-diff" : "")">
                                        <td>@key</td>
                                        <td class="tw-mono">@val1</td>
                                        <td class="tw-mono">@val2</td>
                                        <td>
                                            @if (val1 != val2) { <span class="tw-badge warning">Changed</span> } else { <span class="text-muted">Same</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="compare-actions">
                    <button class="tw-btn-ghost" @onclick="ExportComparisonAsync">📥 Export Comparison</button>
                    <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/experiments")'>🔙 Back to History</button>
                </div>
            </div>
        }
</div>

@code {
    private List<TrainingHistoryItem>? _experiments;
    private TrainWise.Web.Models.ExperimentDetail? _fullExp1;
    private TrainWise.Web.Models.ExperimentDetail? _fullExp2;
    private string? _exp1Id;
    private string? _exp2Id;
    private bool _isComparing = false;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        await LoadExperiments();
    }

    private async Task LoadExperiments()
    {
        try
        {
            var response = await ExperimentApi.GetTrainingHistoryAsync();
            _experiments = response?.TrainingHistory;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading experiments");
        }
    }

    private void OnExperimentSelected() 
    { 
        if (!string.IsNullOrEmpty(_exp1Id) && !string.IsNullOrEmpty(_exp2Id))
        {
            var exp1 = _experiments?.FirstOrDefault(e => e.ExperimentId.ToString() == _exp1Id);
            var exp2 = _experiments?.FirstOrDefault(e => e.ExperimentId.ToString() == _exp2Id);
            
            if (exp1 != null && exp2 != null && exp1.DatasetId != exp2.DatasetId)
            {
                _exp2Id = null; // Reset second if dataset mismatch
            }
        }
        StateHasChanged(); 
    }

    private async Task CompareAsync()
    {
        if (string.IsNullOrEmpty(_exp1Id) || string.IsNullOrEmpty(_exp2Id)) return;
        _isComparing = true;
        try
        {
            _fullExp1 = await ExperimentApi.GetAsync(Guid.Parse(_exp1Id));
            _fullExp2 = await ExperimentApi.GetAsync(Guid.Parse(_exp2Id));
        }
        finally
        {
            _isComparing = false;
        }
    }

    private RenderFragment RenderVariance(double? val1, double? val2, bool higherIsBetter)
    {
        if (val1 == null || val2 == null) return @<span class="text-muted">-</span>;
        var diff = val2.Value - val1.Value;
        var absDiff = Math.Abs(diff);
        var isPositive = higherIsBetter ? diff > 0 : diff < 0;
        var colorClass = diff == 0 ? "text-muted" : (isPositive ? "text-success" : "text-danger");
        var prefix = diff > 0 ? "+" : "";

        return @<span class="@colorClass font-bold">@prefix@diff.ToString("F3")</span>;
    }

    private static string FormatHyperparamValue(object? value)
    {
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.Null => "Default",
                System.Text.Json.JsonValueKind.True => "True",
                System.Text.Json.JsonValueKind.False => "False",
                _ => je.ToString()
            };
        }
        return value?.ToString() ?? "Default";
    }

    private IEnumerable<string> GetAllKeys(Dictionary<string, object>? dict1, Dictionary<string, object>? dict2)
    {
        var keys = new HashSet<string>();
        if (dict1 != null) keys.UnionWith(dict1.Keys);
        if (dict2 != null) keys.UnionWith(dict2.Keys);
        return keys.OrderBy(k => k);
    }

    private async Task ExportComparisonAsync()
    {
        if (_fullExp1 is null || _fullExp2 is null) return;
        var comparison = new { ModelA = _fullExp1, ModelB = _fullExp2, ComparedAt = DateTime.UtcNow };
        var json = System.Text.Json.JsonSerializer.Serialize(comparison, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        await JSRuntime.InvokeVoidAsync("downloadFile", bytes, "model_comparison.json");
    }
}

<style>
    .compare-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .selectors-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 200px;
        gap: 24px;
        align-items: flex-end;
    }

    .selector-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .selector-item label {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .table-card { padding: 0 !important; overflow: hidden; }

    .table-scroll {
        width: 100%;
        overflow-x: auto;
    }

    .compare-table {
        width: 100%;
        border-collapse: collapse;
    }

    .compare-table th {
        background: rgba(255, 255, 255, 0.02);
        padding: 24px;
        text-align: left;
        border-bottom: 2px solid var(--border-subtle);
    }

    .model-head {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .model-head h4 { margin: 0; font-size: 1.1rem; color: var(--text-h1); }

    .compare-table td {
        padding: 16px 24px;
        font-size: 0.9rem;
        border-bottom: 1px solid var(--border-subtle);
        color: var(--text-body);
    }

    .table-section td {
        background: rgba(255, 255, 255, 0.03);
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--accent-violet);
        letter-spacing: 1px;
        padding: 12px 24px;
    }

    .row-diff td {
        background: rgba(251, 191, 36, 0.03);
    }

    .tw-info-text {
        font-size: 0.75rem;
        color: var(--accent-violet);
        opacity: 0.8;
        margin-top: 4px;
        font-style: italic;
    }

    .text-success { color: #34d399 !important; }
    .text-danger { color: #f87171 !important; }
    .font-bold { font-weight: 700; }

    .compare-actions {
        display: flex;
        justify-content: flex-end;
        gap: 16px;
        margin-top: 24px;
    }

    .spinner-inline {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@media (max-width: 1024px) {
        .selectors-grid { grid-template-columns: 1fr; }
    }
</style>
