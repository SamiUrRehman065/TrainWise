@page "/experiments"
@page "/history"
@inject TrainWise.Web.Services.Api.ExperimentApi ExperimentApi
@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@using TrainWise.Web.Components.Common

<div class="experiments-page">
    <section class="tw-section-header">
        <h1 class="text-gradient">Training History</h1>
        <p class="subtitle">Review all your experiment runs, performance metrics, and model insights.</p>
        <div class="header-actions">
            <button class="tw-btn-primary" @onclick='() => NavManager.NavigateTo("/training")'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                <span>New training</span>
            </button>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="tw-card animate-fade-up" style="text-align: center; padding: 60px;">
            <div class="loading-spinner"></div>
            <p class="stat-label" style="margin-top: 16px;">Loading experiments...</p>
        </div>
    }
    else if (_history is null || _history.Items.Count == 0)
        {
            <div class="tw-card empty-state animate-fade-up">
                <div class="empty-icon">📊</div>
                <h3>No experiments yet</h3>
                <p class="subtitle">Start by uploading a dataset and training your first model.</p>
                <button class="tw-btn-primary" style="margin-top: 24px;" @onclick='() => NavManager.NavigateTo("/datasets")'>Get started</button>
            </div>
        }
        else
        {
            <div class="experiments-search animate-fade-up">
                <div class="search-input-wrapper">
                    <span class="search-icon">🔍</span>
                    <input type="text" class="tw-input" placeholder="Search by model or dataset name..." @bind="_searchTerm" @bind:event="oninput" />
                </div>
                <button class="tw-btn-ghost" @onclick='() => NavManager.NavigateTo("/experiments/compare")'>
                    ⚖️ Compare Runs
                </button>
            </div>

            <div class="experiments-list">
                @foreach (var item in FilteredHistory.OrderByDescending(x => x.CreatedAt))
                {
                    <div class="tw-card experiment-card animate-fade-up">
                        <div class="card-left">
                            <div class="model-info">
                                <h3>@item.ModelName</h3>
                                <span class="tw-badge info">@item.TaskType</span>
                            </div>
                            <div class="meta-info">
                                <div class="meta-item">
                                    <span class="meta-icon">📁</span>
                                    <span class="text-body">@item.DatasetName</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-icon">📅</span>
                                    <span class="text-muted">@item.CreatedAt.ToString("MMM dd, yyyy • HH:mm")</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-center">
                            <div class="metric-display">
                                <span class="stat-label">Performance</span>
                                <span class="stat-number small text-gradient">@item.MetricsSummary</span>
                            </div>
                        </div>

                        <div class="card-right">
                            <div class="experiment-actions">
                                <a href="@($"/experiments/{item.ExperimentId}")" class="tw-btn-ghost btn-sm">Details</a>
                                <a href="@($"/results/{item.ExperimentId}/recommendations")" class="tw-btn-ghost btn-sm">Insights</a>
                                <span class="tw-badge success status-badge">Completed</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
</div>

@code {
    private TrainWise.Web.Models.ExperimentList? _history;
    private bool _isLoading = true;
    private string _searchTerm = "";

    private IEnumerable<TrainWise.Web.Models.ExperimentListItem> FilteredHistory => 
        _history?.Items.Where(x => 
            string.IsNullOrEmpty(_searchTerm) || 
            x.ModelName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) || 
            x.DatasetName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)) ?? 
        Enumerable.Empty<TrainWise.Web.Models.ExperimentListItem>();

    protected override async Task OnInitializedAsync()
    {
        if (!SessionState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        _history = await ExperimentApi.GetHistoryAsync();
        _isLoading = false;
    }
}

<style>
    .experiments-page {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .experiments-search {
        display: flex;
        gap: 16px;
        align-items: center;
        background: var(--bg-surface);
        padding: 16px;
        border-radius: 16px;
        border: 1px solid var(--border-subtle);
    }

    .search-input-wrapper {
        position: relative;
        flex: 1;
    }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1rem;
        opacity: 0.5;
    }

    .search-input-wrapper .tw-input {
        padding-left: 44px;
    }

    .experiments-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .experiment-card {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        align-items: center;
        gap: 32px;
        padding: 20px 24px;
    }

    .model-info {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .model-info h3 {
        margin: 0;
        font-size: 1.15rem;
    }

    .meta-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
    }

    .meta-icon {
        font-size: 1rem;
    }

    .metric-display {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .experiment-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
        align-items: center;
    }

    .status-badge {
        margin-left: 8px;
    }

    .btn-sm {
        padding: 6px 16px !important;
        font-size: 0.8rem !important;
    }

    .empty-state {
        text-align: center;
        padding: 80px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(129, 140, 248, 0.1);
        border-top-color: var(--accent-violet);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto;
    }


    @@media (max-width: 900px) {
        .experiment-card {
            grid-template-columns: 1fr;
            gap: 20px;
            text-align: center;
        }
        .model-info, .meta-item, .experiment-actions {
            justify-content: center;
        }
        .experiments-search {
            flex-direction: column;
        }
        .search-input-wrapper {
            width: 100%;
        }
    }
</style>