@inject TrainWise.Web.Services.State.SessionState SessionState
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<header class="top-nav">
    <div class="nav-container">
        <!-- Logo -->
        <a href="/" class="nav-brand">
            <span class="brand-icon">⚡</span>
            <span class="brand-text">TrainWise</span>
        </a>

        @if (!SessionState.IsAuthenticated)
        {
            <div class="nav-left-links">
                <a href="/" class="nav-link @IsActive("/")">Home</a>
            </div>
        }

        <!-- Links (Center) -->
        <nav class="nav-links">
            @if (SessionState.IsAuthenticated)
            {
                <a href="/" class="nav-link @IsActive("/")">Home</a>
                <a href="/dashboard" class="nav-link @IsActive("/dashboard", "/stats")">Dashboard</a>
                <a href="/datasets" class="nav-link @IsActive("/datasets", "/upload")">Datasets</a>
                <a href="/training" class="nav-link @IsActive("/training", "/train")">Training</a>
                <a href="/experiments" class="nav-link @IsActive("/experiments", "/history")">History</a>
                <a href="/compare" class="nav-link @IsActive("/compare", "/experiments/compare")">Compare</a>
                <a href="/metrics" class="nav-link @IsActive("/metrics")">Metrics</a>
            }
        </nav>

        <!-- User/Auth (Right) -->
        <div class="nav-user">
            @if (SessionState.IsAuthenticated)
            {
                <div class="user-dropdown-container">
                    <button class="user-trigger" @onclick="ToggleDropdown">
                        <div class="user-avatar">
                            @(SessionState.Username?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                        <span class="user-name">@SessionState.Username</span>
                        <span class="dropdown-chevron">▼</span>
                    </button>

                    @if (_isDropdownOpen)
                    {
                        <div class="user-dropdown animate-fade-up">
                            <div class="dropdown-header">
                                <p class="user-display">@SessionState.Username</p>
                                <p class="user-role">Premium Workspace</p>
                            </div>
                            <div class="dropdown-divider"></div>
                            <a href="/profile" class="dropdown-item" @onclick="CloseDropdown">👤 Profile</a>
                            <a href="/settings" class="dropdown-item" @onclick="CloseDropdown">⚙️ Settings</a>
                            <div class="dropdown-divider"></div>
                            <button class="dropdown-item text-danger" @onclick="LogoutAsync">🚪 Logout</button>
                        </div>
                    }
                </div>
            }
            else
            {
                <a href="/login" class="tw-btn-ghost btn-sm">Sign In</a>
                <a href="/signup" class="tw-btn-primary btn-sm">Get Started</a>
            }
        </div>
    </div>
</header>

@if (_isDropdownOpen)
{
    <div class="dropdown-overlay" @onclick="CloseDropdown"></div>
}

@code {
    private string _currentRelativePath = "";
    private bool _isDropdownOpen = false;

    private void ToggleDropdown() => _isDropdownOpen = !_isDropdownOpen;
    private void CloseDropdown() => _isDropdownOpen = false;

    private string IsActive(params string[] paths)
    {
        var currentPath = string.IsNullOrEmpty(_currentRelativePath) ? "/" : "/" + _currentRelativePath.Trim('/');

        foreach (var path in paths)
        {
            if (path == "/")
            {
                if (currentPath == "/") return "active";
                continue;
            }

            var normalizedPath = path.TrimEnd('/');
            if (string.Equals(currentPath, normalizedPath, StringComparison.OrdinalIgnoreCase))
            {
                return "active";
            }
            if (currentPath.StartsWith(normalizedPath + "/", StringComparison.OrdinalIgnoreCase))
            {
                return "active";
            }
        }
        return "";
    }

    protected override void OnInitialized()
    {
        SessionState.OnChanged += StateHasChanged;
        NavManager.LocationChanged += OnLocationChanged;
        UpdateCurrentPath();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateCurrentPath();
        _isDropdownOpen = false;
        StateHasChanged();
    }

    private void UpdateCurrentPath()
    {
        _currentRelativePath = NavManager.ToBaseRelativePath(NavManager.Uri).Split('?', '#')[0] ?? "";
    }

    private async Task LogoutAsync()
    {
        _isDropdownOpen = false;
        SessionState.Clear();
        await SessionState.ClearStorageAsync(JSRuntime);
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    void IDisposable.Dispose()
    {
        SessionState.OnChanged -= StateHasChanged;
        NavManager.LocationChanged -= OnLocationChanged;
    }
}

<style>
    .top-nav {
        position: sticky;
        top: 0;
        z-index: 1000;
        height: 64px;
        background: var(--bg-navbar);
        border-bottom: 1px solid var(--border-subtle);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        display: flex;
        align-items: center;
        padding: 0 40px;
    }

    .nav-container {
        width: 100%;
        max-width: 1440px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        flex-shrink: 0;
    }

    .brand-icon {
        font-size: 1.5rem;
        filter: drop-shadow(0 0 10px rgba(129, 140, 248, 0.4));
    }

    .brand-text {
        font-size: 1.35rem;
        font-weight: 800;
        background: var(--accent-grad);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.8px;
    }

    .nav-left-links {
        margin-left: 32px;
        flex: 1;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(255, 255, 255, 0.02);
        padding: 4px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .nav-link {
        color: var(--text-muted);
        font-weight: 500;
        font-size: 0.85rem;
        padding: 8px 14px;
        border-radius: 8px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        white-space: nowrap;
    }

    .nav-link:hover {
        color: var(--text-h1);
        background: rgba(255, 255, 255, 0.05);
    }

    .nav-link.active {
        color: var(--text-h1);
        background: var(--accent-grad);
        box-shadow: 0 4px 12px rgba(129, 140, 248, 0.2);
    }

    .nav-user {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

    .user-dropdown-container {
        position: relative;
    }

    .user-trigger {
        background: none;
        border: 1px solid var(--border-subtle);
        padding: 4px 12px 4px 4px;
        border-radius: 50px;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .user-trigger:hover {
        background: rgba(255, 255, 255, 0.03);
        border-color: var(--border-active);
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--accent-grad);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.85rem;
        color: white;
    }

    .user-name {
        font-size: 0.85rem;
        color: var(--text-h1);
        font-weight: 600;
    }

    .dropdown-chevron {
        font-size: 0.6rem;
        color: var(--text-muted);
        transition: transform 0.3s ease;
    }

    .user-dropdown {
        position: absolute;
        top: calc(100% + 12px);
        right: 0;
        width: 220px;
        background: var(--bg-surface);
        border: 1px solid var(--border-active);
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        padding: 8px;
        display: flex;
        flex-direction: column;
        backdrop-filter: blur(20px);
    }

    .dropdown-header {
        padding: 12px 16px;
    }

    .user-display {
        margin: 0;
        font-weight: 700;
        color: var(--text-h1);
        font-size: 0.9rem;
    }

    .user-role {
        margin: 0;
        font-size: 0.7rem;
        color: var(--accent-violet);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .dropdown-divider {
        height: 1px;
        background: var(--border-subtle);
        margin: 4px 0;
    }

    .dropdown-item {
        padding: 10px 16px;
        border-radius: 10px;
        color: var(--text-body);
        font-size: 0.9rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 12px;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .dropdown-item:hover {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-h1);
        padding-left: 20px;
    }

    .dropdown-item.text-danger:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .dropdown-overlay {
        position: fixed;
        inset: 0;
        z-index: 999;
    }

    .btn-sm {
        padding: 8px 20px !important;
        font-size: 0.85rem !important;
    }

    @@media (max-width: 1100px) {
        .nav-links { display: none; }
    }
</style>
