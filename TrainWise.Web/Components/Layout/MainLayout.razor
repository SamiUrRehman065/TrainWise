@inherits LayoutComponentBase
@using TrainWise.Web.Components.Navigation
@inject IJSRuntime JSRuntime
@inject TrainWise.Web.Services.State.SessionState SessionState

@if (_isSessionReady)
{
    <div class="app-shell">
        <TopNav />
        <main class="app-main">
            <div class="tw-container">
                @Body
            </div>
        </main>
        <footer class="app-footer">
            <p>&copy; 2026 TrainWise &mdash; Premium ML Training Platform</p>
        </footer>
    </div>
}
else
{
    <div class="app-loading-shell">
        <div class="loading-card">
            <div class="loading-spinner"></div>
            <p class="loading-text">Initializing workspace…</p>
        </div>
    </div>
}

@code {
    private bool _isSessionReady;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SessionState.RestoreFromStorageAsync(JSRuntime);
            await JSRuntime.InvokeVoidAsync("import", "./js/export.js");
            _isSessionReady = true;
            StateHasChanged();
        }
    }
}

<style>
    .app-shell {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background-color: var(--bg-page);
    }

    .app-main {
        flex: 1;
        width: 100%;
        animation: fadeIn 0.8s ease-out;
    }

    .app-footer {
        padding: 32px 24px;
        border-top: 1px solid var(--border-subtle);
        text-align: center;
        background: var(--bg-navbar);
        backdrop-filter: blur(12px);
    }

    .app-footer p {
        margin: 0;
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .app-loading-shell {
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: var(--bg-page);
    }

    .loading-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(129, 140, 248, 0.1);
        border-top-color: var(--accent-violet);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }


    .loading-text {
        font-weight: 600;
        color: var(--text-h1);
    }
</style>
