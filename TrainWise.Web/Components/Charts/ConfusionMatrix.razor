@inject IJSRuntime JS

<div class="chart-container glass-card hover-lift">
    <h4 class="chart-title">Confusion Matrix</h4>
    <div id="@_chartId" class="chart-plot"></div>
</div>

@code {
    [Parameter] public List<List<int>>? Matrix { get; set; }
    [Parameter] public List<string>? Labels { get; set; }

    private string _chartId = $"cm-{Guid.NewGuid():N}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Matrix is not null && Matrix.Count > 0)
        {
            var labels = Labels ?? Matrix.Select((_, i) => $"Class {i}").ToList();
            await JS.InvokeVoidAsync("PlotlyInterop.renderConfusionMatrix", _chartId, Matrix, labels);
        }
    }
}

<style>
    .chart-container {
        padding: var(--space-5);
    }

    .chart-title {
        font-family: var(--font-ui);
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin: 0 0 var(--space-3);
    }

    .chart-plot {
        width: 100%;
        min-height: 350px;
    }
</style>
